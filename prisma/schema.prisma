  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  realmId          String?
  organizationName String?
  environment      String              @default("sandbox")
  status           QboConnectionStatus @default(DISCONNECTED)
  accessToken      String?
  refreshToken     String?
  expiresAt        DateTime?
