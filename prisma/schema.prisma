  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind         String
  inputHash    String
  entityType   String?
  entityId     String?
  outputJson   String
  confidence   Int?
  source       String   @default("heuristic")
  userFeedback String?
  feedbackNote String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, kind, inputHash])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
}

model RecordComment {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entityType String
  entityId   String
  authorId   String?
  authorName String
  kind       String   @default("COMMENT")
  body       String
  createdAt  DateTime @default(now())

  @@index([tenantId, entityType, entityId, createdAt])
  @@index([tenantId, createdAt])
}

enum DrawingDiscipline {
  ARCHITECTURAL
  STRUCTURAL
  MEP
  CIVIL
  LANDSCAPE
  ELECTRICAL
  PLUMBING
  MECHANICAL
  FIRE_PROTECTION
  OTHER
}

/// Drawing register entry — a versioned set of sheets for one project +
/// discipline. Captures the full Sheet/Spec lineage that req §7.7 asks
/// for: discipline classification, revision history, link to the source
/// Document, and a list of DrawingSheet rows for the sheet register.
model Drawing {
  id             String            @id @default(cuid())
  projectId      String
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  setName        String
  discipline     DrawingDiscipline @default(OTHER)
  revisionNumber Int               @default(0)
  issuedDate     DateTime?
  receivedDate   DateTime          @default(now())
  archived       Boolean           @default(false)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  sheets    DrawingSheet[]
  revisions DrawingRevision[]

  @@index([projectId])
  @@index([projectId, discipline])
}

/**
 * One issued revision of a drawing set. When a new revision uploads,
 * the prior revision is auto-marked superseded and any unaffected
 * sheets carry forward. Distribution log per revision lives in
 * DocumentTransmittal (the recipient + acknowledgement audit trail).
 */
model DrawingRevision {
  id            String    @id @default(cuid())
  drawingId     String
  drawing       Drawing   @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  revisionLabel String // "REV 1", "REV 2", "ISSUE FOR CONSTRUCTION"
  issuedDate    DateTime
  issuedBy      String?
  reason        String? // "ASI 12", "RFI 045 response", etc.
  superseded    Boolean   @default(false)
  supersededAt  DateTime?
  notes         String?
  createdAt     DateTime  @default(now())

  @@unique([drawingId, revisionLabel])
  @@index([drawingId])
}

/// One sheet in a drawing set — e.g. "A0.1 Cover Sheet". `isCurrent`
/// flips to false when superseded by a later revision; we keep the row
/// instead of deleting so cross-references from RFIs / Submittals stay
/// stable.
model DrawingSheet {
  id          String   @id @default(cuid())
  drawingId   String
  drawing     Drawing  @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  sheetNumber String
  title       String
  fileUrl     String?
  pageNumber  Int?
  isCurrent   Boolean  @default(true)
  // Title block extraction (filled by OCR or manual entry) — drives
  // sheet-index search ("show me all detail sheets for stair 1").
  scale       String?
  drawnBy     String?
  checkedBy   String?
  approvedBy  String?
  createdAt   DateTime @default(now())

  rfiPins   RfiDrawingPin[]
  markups   DrawingMarkup[]
  photoPins ProjectPhotoPin[]

  @@unique([drawingId, sheetNumber])
  @@index([drawingId])
}

/**
 * Drawing markup layer — geometric annotations (rectangles, circles,
 * polylines, text callouts, cloud) drawn on a sheet. Stored as a
 * normalized geometry list so the renderer can paint them on top of
 * the PDF/image without re-saving the source asset.
 */
model DrawingMarkup {
  id             String       @id @default(cuid())
  drawingSheetId String
  drawingSheet   DrawingSheet @relation(fields: [drawingSheetId], references: [id], onDelete: Cascade)
  authorId       String?
  authorName     String?
  shape          String // "rect" | "circle" | "polyline" | "text" | "cloud"
  color          String       @default("#ef4444")
  strokeWidth    Float        @default(2)
  geometryJson   String // {x,y,w,h} or {points:[[x,y],…]} or {x,y,text}
  noteText       String?
  resolved       Boolean      @default(false)
  resolvedAt     DateTime?
  createdAt      DateTime     @default(now())

  @@index([drawingSheetId])
}

/**
 * Project photo library. Photos belong to a project, optionally an
 * album, and may be pinned to one or more drawing sheet locations.
 * EXIF capture (geo, time) and AI auto-tags drive search + clustering.
 */
model ProjectPhoto {
  id             String             @id @default(cuid())
  projectId      String
  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  albumId        String?
  album          ProjectPhotoAlbum? @relation(fields: [albumId], references: [id], onDelete: SetNull)
  fileUrl        String
  thumbnailUrl   String?
  caption        String?
  // EXIF / capture metadata — auto-populated on upload when available.
  capturedAt     DateTime?
  geoLat         Float?
  geoLng         Float?
  geoAccuracyM   Float?
  weatherJson    String? // weather conditions at capture time
  // AI auto-tags (trade, room, defect type) — list of strings.
  aiTagsJson     String             @default("[]")
  uploadedById   String?
  uploadedByName String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  pins ProjectPhotoPin[]

  @@index([projectId])
  @@index([projectId, capturedAt])
  @@index([albumId])
}

/**
 * Photo album — phase-based ("Foundation", "Roughing"), area-based
 * ("Level 1 East"), or trade-based ("Concrete"). Used to group photos
 * for owner reports + time-lapse sequencing.
 */
model ProjectPhotoAlbum {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  coverPhotoUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  photos ProjectPhoto[]

  @@unique([projectId, name])
  @@index([projectId])
}

/**
 * Pin one photo to one drawing sheet at specific coordinates. Lets
 * field crews capture defects in place + show owners exactly where.
 */
model ProjectPhotoPin {
  id             String       @id @default(cuid())
  photoId        String
  photo          ProjectPhoto @relation(fields: [photoId], references: [id], onDelete: Cascade)
  drawingSheetId String
  drawingSheet   DrawingSheet @relation(fields: [drawingSheetId], references: [id], onDelete: Cascade)
  xRatio         Float
  yRatio         Float
  createdAt      DateTime     @default(now())

  @@index([photoId])
  @@index([drawingSheetId])
}

/// CSI MasterFormat specification section. csiDivision is the 2-digit
/// division code ("03" = Concrete, "09" = Finishes); sectionCode is the
/// full 6-digit code ("03 30 00"). Specs are project-scoped because two
/// projects can share a division but have different section content.
model SpecSection {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  csiDivision    String
  sectionCode    String
  title          String
  fileUrl        String?
  revisionNumber Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([projectId, sectionCode])
  @@index([projectId])
  @@index([projectId, csiDivision])
}

enum CandidateStatus {
  NEW
  SCREENING
  INTERVIEWING
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
  ARCHIVED
}

enum JobReqStatus {
  DRAFT
  OPEN
  ON_HOLD
  FILLED
  CANCELLED
  CLOSED
}

enum SubmissionStage {
  SUBMITTED
  RECRUITER_SCREEN
  TECH_SCREEN
  CLIENT_INTERVIEW
  REFERENCE_CHECK
  OFFER_EXTENDED
  OFFER_ACCEPTED
  OFFER_DECLINED
  PLACED
  REJECTED
  WITHDRAWN
}

enum PlacementStatus {
  PENDING_START
  ACTIVE
  EXTENDED
  ENDING_SOON
  ENDED
  TERMINATED
  CONVERTED
}

/// ATS candidate. Tenant-scoped because recruiters work within a single
/// company/agency tenant; cross-tenant candidate sharing is not in scope
/// per req §7.1A. Resume URL points at the storage adapter (PR #15).
model Candidate {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  email           String?
  phone           String?
  city            String?
  state           String?
  country         String?         @default("US")
  status          CandidateStatus @default(NEW)
  laborCategory   String?
  primarySkill    String?
  skillsJson      String          @default("[]")
  resumeUrl       String?
  linkedInUrl     String?
  rateExpectation Float?
  source          String?
  ownerUserId     String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  submissions     Submission[]
  placements      Placement[]
  onboardingPaths OnboardingPath[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, laborCategory])
}

/// Open job requisition under a tenant. Optional projectId binds the req
/// to a construction project (e.g. a self-perform crew slot); reqs that
/// don't tie to a project (corporate roles, recruiter pools) leave it null.
model JobRequisition {
  id              String       @id @default(cuid())
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  reqNumber       String
  title           String
  hiringManager   String?
  laborCategory   String?
  location        String?
  remoteAllowed   Boolean      @default(false)
  rateMin         Float?
  rateMax         Float?
  status          JobReqStatus @default(DRAFT)
  openings        Int          @default(1)
  filledCount     Int          @default(0)
  description     String?
  postedDate      DateTime?
  targetStartDate DateTime?
  closedAt        DateTime?
  closedReason    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  submissions Submission[]

  @@unique([tenantId, reqNumber])
  @@index([tenantId, status])
  @@index([projectId])
}

/// Candidate × JobRequisition pipeline state. One row per submission
/// attempt — a candidate withdrawn and re-submitted gets a new row so
/// the activity history stays append-only.
model Submission {
  id            String          @id @default(cuid())
  tenantId      String
  candidateId   String
  candidate     Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  reqId         String
  req           JobRequisition  @relation(fields: [reqId], references: [id], onDelete: Cascade)
  stage         SubmissionStage @default(SUBMITTED)
  recruiterName String?
  rateOffered   Float?
  notes         String?
  submittedAt   DateTime        @default(now())
  decidedAt     DateTime?
  rejectReason  String?

  placement Placement?

  @@unique([candidateId, reqId])
  @@index([tenantId])
  @@index([reqId, stage])
  @@index([candidateId])
}

/// Active or completed placement of a candidate against a project /
/// contract. Captures bill/pay rate split and the lifecycle dates that
/// drive renewal alerts (req §7.1A placements). One submission can
/// produce at most one placement; subsequent re-engagements create new
/// placements pointing at fresh submissions.
model Placement {
  id              String          @id @default(cuid())
  tenantId        String
  candidateId     String
  candidate       Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  submissionId    String?         @unique
  submission      Submission?     @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  projectId       String?
  project         Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contractRef     String?
  laborCategory   String?
  department      String?
  startDate       DateTime
  endDate         DateTime?
  billRate        Float?
  payRate         Float?
  status          PlacementStatus @default(PENDING_START)
  performanceNote String?
  redeployable    Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  onboardingPath OnboardingPath?

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([projectId])
  @@index([candidateId])
}

enum CommissionStatus {
  ACCRUED
  PENDING_APPROVAL
  APPROVED
  PAID
  HELD
  REVERSED
}

enum CommissionSourceType {
  OPPORTUNITY
  PROJECT
  CONTRACT
  PAY_APPLICATION
  CHANGE_ORDER
  MANUAL
}

/// Tenant-level commission rule. ratePct is the percentage applied to the
/// `basis` of a CommissionAccrual; appliesTo scopes the rule to a single
/// source-entity type (e.g. opportunity awards, contract executions). A
/// rule with appliesTo = OPPORTUNITY and ratePct = 0.05 means "pay 5% of
/// the basis amount when an opportunity is awarded." Rules can stack —
/// multiple rules may produce accruals from the same source event, each
/// going to a different recipient role.
model CommissionRule {
  id             String               @id @default(cuid())
  tenantId       String
  tenant         Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  appliesTo      CommissionSourceType
  recipientRole  UserRoleTemplate?
  ratePct        Float                @default(0)
  flatAmount     Float?
  cap            Float?
  active         Boolean              @default(true)
  effectiveFrom  DateTime?
  effectiveUntil DateTime?
  notesJson      String               @default("{}")
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  accruals CommissionAccrual[]

  @@index([tenantId, appliesTo])
  @@index([tenantId, active])
}

/// One commission line for one recipient against one source event.
/// `basis` is the dollar amount the rate is applied to; `amount` is the
/// computed payable. Status moves through ACCRUED → PENDING_APPROVAL →
/// APPROVED → PAID; HELD pauses payout (e.g. pending project close);
/// REVERSED writes a corresponding negative entry.
model CommissionAccrual {
  id              String               @id @default(cuid())
  tenantId        String
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ruleId          String?
  rule            CommissionRule?      @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  recipientName   String
  recipientRole   UserRoleTemplate?
  recipientUserId String?
  sourceType      CommissionSourceType
  sourceId        String
  sourceLabel     String?
  basis           Float                @default(0)
  ratePct         Float                @default(0)
  amount          Float                @default(0)
  status          CommissionStatus     @default(ACCRUED)
  earnedAt        DateTime             @default(now())
  approvedAt      DateTime?
  approvedBy      String?
  paidAt          DateTime?
  paidBy          String?
  reversedAt      DateTime?
  reversedReason  String?
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, sourceType, sourceId])
  @@index([tenantId, recipientUserId])
}

enum CaptureStage {
  IDENTIFIED
  QUALIFYING
  CAPTURE
  PROPOSAL
  EVALUATION
  AWARDED
  LOST
  WITHDRAWN
}

enum SetAsideCode {
  NONE
  SMALL_BUSINESS
  WOSB
  EDWOSB
  HUBZONE
  EIGHT_A
  SDVOSB
  TOTAL_SMALL_BUSINESS
  PARTIAL_SMALL_BUSINESS
}

enum ColorTeamPhase {
  PINK
  RED
  GOLD
  WHITE
  BLACK
  GREEN
}

enum GoNoGoDecisionType {
  GO
  NO_GO
  CONDITIONAL_GO
  DEFERRED
}

/// Federal capture record. Extends the generic Opportunity model with
/// the capture-specific lifecycle req §7.1A demands: stage, vehicle,
/// agency, set-aside, capture lead, NAICS, capture plan url, win
/// strategy, and discriminators. Tied to an Opportunity row when the
/// capture is reflected on the BD pipeline; standalone otherwise.
model CaptureRecord {
  id                 String       @id @default(cuid())
  tenantId           String
  tenant             Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  opportunityId      String?      @unique
  opportunity        Opportunity? @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  title              String
  agency             String?
  subAgency          String?
  contractVehicle    String?
  solicitationNumber String?
  naicsCode          String?
  setAside           SetAsideCode @default(NONE)
  estimatedValue     Float?
  rfpReleaseDate     DateTime?
  proposalDueDate    DateTime?
  awardDate          DateTime?
  stage              CaptureStage @default(IDENTIFIED)
  captureLead        String?
  proposalLead       String?
  pricingLead        String?
  winStrategy        String?
  capturePlanUrl     String?
  discriminators     String?
  pwinPercent        Float?
  notes              String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  milestones       CaptureMilestone[]
  colorTeamReviews ColorTeamReview[]
  decisions        GoNoGoDecision[]
  teamingPartners  TeamingPartner[]

  @@index([tenantId])
  @@index([tenantId, stage])
  @@index([tenantId, agency])
}

/// Calendar milestone within a capture (RFP release, Q&A close, draft
/// due, color reviews, submit). dueAt is the planned date; completedAt
/// records actuals.
model CaptureMilestone {
  id          String        @id @default(cuid())
  captureId   String
  capture     CaptureRecord @relation(fields: [captureId], references: [id], onDelete: Cascade)
  label       String
  dueAt       DateTime
  completedAt DateTime?
  ownerName   String?
  notes       String?
  createdAt   DateTime      @default(now())

  @@index([captureId])
}

/// Color-team review session — pink/red/gold/etc. — per the federal
/// proposal lifecycle. summaryUrl points at the review readout document
/// (managed via the storage adapter).
model ColorTeamReview {
  id           String         @id @default(cuid())
  captureId    String
  capture      CaptureRecord  @relation(fields: [captureId], references: [id], onDelete: Cascade)
  phase        ColorTeamPhase
  scheduledAt  DateTime
  completedAt  DateTime?
  facilitator  String?
  attendees    String?
  scoreOverall Int?
  summaryUrl   String?
  notes        String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([captureId])
  @@index([captureId, phase])
}

/// Go / no-go decision with reasoning, approver, and supporting context.
/// Captures append-only — a CONDITIONAL_GO followed by a NO_GO writes
/// two rows so the rationale chain stays auditable.
model GoNoGoDecision {
  id             String             @id @default(cuid())
  captureId      String
  capture        CaptureRecord      @relation(fields: [captureId], references: [id], onDelete: Cascade)
  decisionAt     DateTime           @default(now())
  decision       GoNoGoDecisionType
  decidedBy      String
  rationale      String
  conditions     String?
  pwinAtDecision Float?
  bidNoBidScore  Float?

  @@index([captureId, decisionAt])
}

/// Teaming partner on a federal pursuit — prime/sub, workshare,
/// teaming agreement status. workSharePct is the planned percentage of
/// the eventual award.
model TeamingPartner {
  id               String        @id @default(cuid())
  captureId        String
  capture          CaptureRecord @relation(fields: [captureId], references: [id], onDelete: Cascade)
  partnerName      String
  role             String
  workSharePct     Float?
  taSignedAt       DateTime?
  ndaSignedAt      DateTime?
  capabilitiesJson String        @default("[]")
  notes            String?
  createdAt        DateTime      @default(now())

  @@index([captureId])
}

enum OnboardingPathStatus {
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum OnboardingStepKind {
  DOCUMENT
  TRAINING
  SIGNOFF
  ACCESS_PROVISION
  EQUIPMENT
  COMPLIANCE_CHECK
  ORIENTATION
  OTHER
}

enum OnboardingStepStatus {
  PENDING
  IN_PROGRESS
  WAIVED
  COMPLETE
  BLOCKED
}

/// Onboarding path — a personalised sequence of pre-start tasks for a
/// new hire / placement. Status drives whether the path appears in the
/// "active onboarding" view; an OnboardingPath is closed when every
/// non-waived step reaches COMPLETE (the route enforces this).
model OnboardingPath {
  id              String               @id @default(cuid())
  tenantId        String
  tenant          Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidateId     String?
  candidate       Candidate?           @relation(fields: [candidateId], references: [id], onDelete: SetNull)
  placementId     String?              @unique
  placement       Placement?           @relation(fields: [placementId], references: [id], onDelete: SetNull)
  personName      String
  role            String?
  startDateTarget DateTime?
  status          OnboardingPathStatus @default(PLANNED)
  ownerName       String?
  notes           String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  steps OnboardingStep[]

  @@index([tenantId, status])
  @@index([candidateId])
}

/// One step in an OnboardingPath. `kind` lets the UI render the right
/// affordance (file upload for DOCUMENT, link out for TRAINING, etc.).
/// dueAt drives reminders; completedAt closes it. WAIVED is the manager
/// override.
model OnboardingStep {
  id          String               @id @default(cuid())
  pathId      String
  path        OnboardingPath       @relation(fields: [pathId], references: [id], onDelete: Cascade)
  ordering    Int                  @default(0)
  kind        OnboardingStepKind
  label       String
  description String?
  status      OnboardingStepStatus @default(PENDING)
  required    Boolean              @default(true)
  dueAt       DateTime?
  completedAt DateTime?
  completedBy String?
  documentUrl String?
  blocker     String?
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([pathId, ordering])
  @@index([pathId, status])
}

/// Daily crew assignment (req §7.12). One row per (project, day, crew,
/// cost code, activity). Captures planned vs actual headcount + hours.
/// crewName is a free string today — when a Crew master model lands it
/// becomes a FK without changing the assignment shape.
model CrewAssignment {
  id               String    @id @default(cuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dailyLogId       String?
  dailyLog         DailyLog? @relation(fields: [dailyLogId], references: [id], onDelete: SetNull)
  assignedDate     DateTime
  crewName         String
  foreman          String?
  // costCode defaults to "" so @@unique([projectId, assignedDate, crewName,
  // costCode]) is well-defined when callers omit a cost code. Storing ""
  // instead of null keeps Postgres + SQLite unique semantics consistent
  // (null != null in unique indexes on both providers).
  costCode         String    @default("")
  activity         String?
  plannedHeadcount Int       @default(0)
  actualHeadcount  Int       @default(0)
  plannedHours     Float     @default(0)
  actualHours      Float     @default(0)
  shift            String?
  notes            String?
  // Same geotag pattern as DailyLog so a spread crew on a linear job can
  // be plotted by station / segment / lat-lon.
  segment          String?
  station          String?
  latitude         Float?
  longitude        Float?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([projectId, assignedDate, crewName, costCode])
  @@index([projectId, assignedDate])
  @@index([dailyLogId])
}

// ─────────────────────────────────────────────────────────────────
// COMPANY COMPLIANCE — tenant-admin-only repository for the GC's
// own licensing, insurance, bonding, certifications, and safety
// record. Distinct from Vendor*/InsuranceCert which are for subs.
// Surfaces in /settings/company. Per-project requirements link via
// ProjectComplianceLink so each job shows which company records
// cover it.
// ─────────────────────────────────────────────────────────────────

/// Company-wide profile — DBA, EIN, registered address, NAICS, SAM
/// status. One row per tenant.
model CompanyProfile {
  id                  String    @id @default(cuid())
  tenantId            String    @unique
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  legalName           String
  dbaName             String?
  ein                 String?
  duns                String?
  cageCode            String?
  uei                 String?
  entityType          String?
  yearFounded         Int?
  primaryAddress      String?
  city                String?
  state               String?
  postalCode          String?
  country             String    @default("US")
  naicsCodesJson      String    @default("[]")
  samStatus           String?
  samExpiresAt        DateTime?
  primaryContactName  String?
  primaryContactEmail String?
  primaryContactPhone String?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

/// Tenant company contractor / specialty / business license per
/// state + jurisdiction.
model CompanyLicense {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  licenseType       String
  licenseNumber     String
  jurisdictionLevel String    @default("STATE")
  state             String?
  jurisdiction      String?
  issuedAt          DateTime?
  expiresAt         DateTime?
  status            String    @default("ACTIVE")
  scopeOfWork       String?
  classification    String?
  bondingRequired   Boolean   @default(false)
  documentUrl       String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  projectLinks ProjectComplianceLink[] @relation("ProjectLink_License")

  @@unique([tenantId, licenseNumber, state])
  @@index([tenantId])
  @@index([expiresAt])
}

/// Tenant company insurance certificates — GL, WC, Auto, Pro,
/// Umbrella, Builders Risk, Pollution, Cyber.
model CompanyInsurance {
  id                        String   @id @default(cuid())
  tenantId                  String
  tenant                    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  policyType                String
  carrier                   String
  policyNumber              String
  effectiveDate             DateTime
  expiresAt                 DateTime
  perOccurrenceLimit        Float    @default(0)
  aggregateLimit            Float    @default(0)
  deductible                Float    @default(0)
  statesCoveredJson         String   @default("[]")
  additionalInsuredsJson    String   @default("[]")
  waiverOfSubrogation       Boolean  @default(false)
  primaryAndNoncontributory Boolean  @default(false)
  documentUrl               String?
  notes                     String?
  status                    String   @default("ACTIVE")
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  projectLinks ProjectComplianceLink[] @relation("ProjectLink_Insurance")

  @@unique([tenantId, policyNumber])
  @@index([tenantId, policyType])
  @@index([expiresAt])
}

/// Surety bonding capacity and per-project bonds.
model CompanyBond {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bondType          String
  surety            String
  bondNumber        String?
  capacityAggregate Float     @default(0)
  capacitySingle    Float     @default(0)
  bondAmount        Float     @default(0)
  effectiveDate     DateTime?
  expiresAt         DateTime?
  premium           Float     @default(0)
  rate              Float?
  documentUrl       String?
  notes             String?
  status            String    @default("ACTIVE")
  projectId         String?
  project           Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  projectLinks ProjectComplianceLink[] @relation("ProjectLink_Bond")

  @@index([tenantId, bondType])
  @@index([projectId])
  @@index([expiresAt])
}

/// Set-aside certifications — DBE, MWBE, WBE, SDVOSB, HUBZONE,
/// 8(a), Small Business, ESBE.
model CompanyCertification {
  id                String    @id @default(cuid())
  tenantId          String
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  certificationType String
  certifyingAgency  String
  certificateNumber String?
  issuedAt          DateTime?
  expiresAt         DateTime?
  status            String    @default("ACTIVE")
  state             String?
  jurisdiction      String?
  scope             String?
  documentUrl       String?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  projectLinks ProjectComplianceLink[] @relation("ProjectLink_Certification")

  @@unique([tenantId, certificationType, certifyingAgency])
  @@index([tenantId])
  @@index([expiresAt])
}

/// Year-over-year safety metrics. EMR feeds prequalification scoring
/// and insurance underwriting.
model CompanySafetyMetric {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reportingYear   Int
  emrRate         Float?
  trirRate        Float?
  dartRate        Float?
  laborHours      Float?
  recordableCount Int      @default(0)
  fatalityCount   Int      @default(0)
  oshaCitations   Int      @default(0)
  oshaForm300aUrl String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([tenantId, reportingYear])
  @@index([tenantId])
}

/// Per-project compliance-requirement link. Each project's contract
/// specifies what licensing/COIs/bonds/certs are required; this row
/// attaches the company-level record that satisfies the requirement.
/// Exactly ONE of the four FK fields is non-null per row.
model ProjectComplianceLink {
  id                     String                @id @default(cuid())
  projectId              String
  project                Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requirementType        String
  companyLicenseId       String?
  companyLicense         CompanyLicense?       @relation("ProjectLink_License", fields: [companyLicenseId], references: [id], onDelete: SetNull)
  companyInsuranceId     String?
  companyInsurance       CompanyInsurance?     @relation("ProjectLink_Insurance", fields: [companyInsuranceId], references: [id], onDelete: SetNull)
  companyBondId          String?
  companyBond            CompanyBond?          @relation("ProjectLink_Bond", fields: [companyBondId], references: [id], onDelete: SetNull)
  companyCertificationId String?
  companyCertification   CompanyCertification? @relation("ProjectLink_Certification", fields: [companyCertificationId], references: [id], onDelete: SetNull)
  requirementText        String?
  satisfied              Boolean               @default(false)
  verifiedAt             DateTime?
  verifiedBy             String?
  notes                  String?
  createdAt              DateTime              @default(now())

  @@index([projectId, requirementType])
  @@index([companyLicenseId])
  @@index([companyInsuranceId])
  @@index([companyBondId])
  @@index([companyCertificationId])
}
