model Tenant {
  id                String      @id @default(cuid())
  name              String
  slug              String      @unique
  primaryMode       ProjectMode
  enabledModes      String      @default("[]")
  featurePacks      String      @default("[]")
  terminology       String      @default("{}")
  brandingTheme     String?
  // Backup config (PR #29). When backupEnabled is true the nightly cron
  // dumps this tenant's data graph to ./uploads/backups/<slug>/<date>.json
  // AND, if backupDirectory is set, copies the same file there. The
  // recommended setup is to point backupDirectory at a OneDrive or
  // Google Drive sync folder so the host's desktop client uploads it
  // off-machine automatically.
  backupEnabled     Boolean     @default(true)
  backupDirectory   String?
  lastBackupAt      DateTime?
  lastBackupBytes   Int?
  lastBackupError   String?
  // Per-tenant LLM keys (pass-14). When set, aiCall reads from the
  // tenant's key first, falling back to the platform's env-var key
  // only when the tenant hasn't configured one. Stored encrypted at
  // rest using KMS_SECRET; decrypted only when constructing the
  // outbound API request. Setting these lets each customer plug in
  // their own OpenAI/Anthropic billing.
  openaiKeyEnc      String?
  anthropicKeyEnc   String?
  preferredProvider String?     @default("openai")
  // Display preferences (pass-25). Per-tenant currency + locale lets
  // a non-US customer see their numbers as €/£/CA$ etc. Defaults to
  // USD + en-US so existing US tenants are unchanged.
  currency          String      @default("USD")
  locale            String      @default("en-US")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  businessUnits             BusinessUnit[]
  memberships               Membership[]
  projects                  Project[]
  companies                 Company[]
  contacts                  Contact[]
  auditEvents               AuditEvent[]
  workflowTemplates         WorkflowTemplate[]
  notificationRules         NotificationRule[]
  historicalEstimates       HistoricalEstimate[]
  opportunities             Opportunity[]
  vendors                   Vendor[]
  rfpSources                RfpSource[]
  rfpListings               RfpListing[]
  bidDrafts                 BidDraft[]
  xeroConnection            XeroConnection?
  qboConnection             QboConnection?
  chartOfAccounts           ChartOfAccount[]
  financialStatements       FinancialStatement[]
  journalEntries            JournalEntryRow[]
  invoiceInbox              InvoiceInboxConnection?
  invoiceInboxMessages      InvoiceInboxMessage[]
  alertRules                AlertRule[]
  alertEvents               AlertEvent[]
  historicalImports         HistoricalImport[]
  aiRuns                    AiRunLog[]
  recordComments            RecordComment[]
  candidates                Candidate[]
  jobRequisitions           JobRequisition[]
  commissionRules           CommissionRule[]
  commissionAccruals        CommissionAccrual[]
  captureRecords            CaptureRecord[]
  onboardingPaths           OnboardingPath[]
  bidProfile                TenantBidProfile?
  contractorLicenses        ContractorLicense[]
  documentTransmittals      DocumentTransmittal[]
  costCodes                 CostCode[]
  vendorPrequals            VendorPrequalification[]
  guestAccounts             GuestAccount[]
  apiTokens                 ApiToken[]
  webhookEndpoints          WebhookEndpoint[]
  emailDigests              EmailDigest[]
  accountingPeriods         AccountingPeriod[]
  balanceSheetSnapshots     BalanceSheetSnapshot[]
  cashFlowForecasts         CashFlowForecast[]
  cashFlowStatements        CashFlowStatement[]
  fleetAssets               FleetAsset[]
  employees                 Employee[]
  payrollRuns               PayrollRun[]
  certifiedPayroll          CertifiedPayrollRecord[]
  vendor1099Records         Vendor1099Record[]
  qualityChecklistTemplates QualityChecklistTemplate[]
  capitalPrograms           CapitalProgram[]
  consolidatedReports       ConsolidatedReport[]
  // Company compliance — tenant's own licensing, insurance, bonding,
  // certifications, safety record. Distinct from Vendor* records,
  // which are about subs. Surfaces in /settings/company.
  companyProfile            CompanyProfile?
  companyLicenses           CompanyLicense[]
  companyInsurances         CompanyInsurance[]
  companyBonds              CompanyBond[]
  companyCertifications     CompanyCertification[]
  companySafetyMetrics      CompanySafetyMetric[]
}

model BusinessUnit {
  id                  String      @id @default(cuid())
  tenantId            String
  tenant              Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                String
  code                String
  defaultMode         ProjectMode
  region              String?
  // Legal entity for consolidation — multiple BUs can roll up to one
  // legal entity, multiple legal entities to one tenant. Drives
  // consolidated GL + balance sheet across BUs.
  legalEntityName     String?
  legalEntityEin      String?
  // Inter-company eliminations — when transferring revenue/cost
  // between BUs in the same legal entity, journal entries get tagged
  // with this BU's intercompanyAccount for elimination at consolidation.
  intercompanyAccount String?
  // Per-BU reporting overrides
  fiscalYearEndMonth  Int         @default(12) // 12 = December year-end
  baseCurrency        String      @default("USD")
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  memberships Membership[]
  projects    Project[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

/**
 * Consolidated financial reporting across business units. The
 * consolidation worker runs at month-end / period close and rolls up
 * P&L by entity → consolidated tenant view, applying intercompany
 * eliminations.
 */
model ConsolidatedReport {
  id                            String   @id @default(cuid())
  tenantId                      String
  tenant                        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periodLabel                   String
  periodStart                   DateTime
  periodEnd                     DateTime
  reportType                    String // "PNL" | "BALANCE_SHEET" | "CASH_FLOW"
  // Roll-up data — JSON per row to keep schema flexible; consumer
  // unpacks based on reportType.
  payloadJson                   String
  // Eliminations applied
  intercompanyEliminationsCents Int      @default(0)
  generatedAt                   DateTime @default(now())

  @@unique([tenantId, periodLabel, reportType])
  @@index([tenantId])
}

model User {
  id                String    @id @default(cuid())
  name              String
  email             String    @unique
  password          String
  active            Boolean   @default(true)
  superAdmin        Boolean   @default(false)
  // MFA — TOTP secret encrypted at rest with the global vault key.
  // mfaEnrolledAt is null until enrollment completes; required for
  // sign-in once set.
  mfaSecretEnc      String?
  mfaEnrolledAt     DateTime?
  mfaBackupCodesEnc String? // JSON list of one-time-use codes, encrypted
  // External-IdP sign-on linkage. provider+providerSubject is unique
  // across User; lookup on auth callback.
  ssoProvider       String?
  ssoSubject        String?
  // Session revocation — when this timestamp moves forward, every
  // JWT issued before it is treated as revoked. Bump on logout / role
  // demotion / suspected compromise.
  sessionsRevokedAt DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  memberships Membership[]
  messages    ThreadMessage[]
  tasks       Task[]          @relation("TaskAssignee")
  approvals   Approval[]      @relation("ApprovalApprover")
  auditEvents AuditEvent[]    @relation("AuditActor")
  watchers    Watcher[]
}

model Membership {
  id              String           @id @default(cuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessUnitId  String?
  businessUnit    BusinessUnit?    @relation(fields: [businessUnitId], references: [id])
  roleTemplate    UserRoleTemplate
  permissionsJson String           @default("{}")
  createdAt       DateTime         @default(now())

  @@unique([tenantId, userId])
}

model Company {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  companyType String
  market      String?
  region      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts Contact[]

  @@index([tenantId])
}

model Contact {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  name      String
  email     String?
  phone     String?
  roleTitle String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([companyId])
}

model Project {
  id                String        @id @default(cuid())
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessUnitId    String?
  businessUnit      BusinessUnit? @relation(fields: [businessUnitId], references: [id])
  name              String
  code              String
  mode              ProjectMode
  stage             ProjectStage  @default(PRECONSTRUCTION)
  address           String?
  ownerName         String?
  contractType      String?
  contractValue     Decimal?
  marginTargetPct   Float?
  progressPct       Float         @default(0)
  healthScore       Int           @default(75)
  startDate         DateTime?
  endDate           DateTime?
  configurationJson String        @default("{}")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  threads              Thread[]
  tasks                Task[]
  documents            Document[]
  rfis                 RFI[]
  submittals           Submittal[]
  dailyLogs            DailyLog[]
  budgets              Budget[]
  quantities           QuantityBudget[]
  productionEntries    ProductionEntry[]
  tickets              Ticket[]
  safetyIncidents      SafetyIncident[]
  punchItems           PunchItem[]
  meetings             Meeting[]
  workflowRuns         WorkflowRun[]
  watchers             Watcher[]
  approvalRoutes       ApprovalRoute[]
  equipmentRecords     EquipmentRecord[]
  materialRecords      MaterialRecord[]
  changeOrders         ChangeOrder[]
  scheduleTasks        ScheduleTask[]
  contracts            Contract[]
  payApplications      PayApplication[]
  lienWaivers          LienWaiver[]
  inspections          Inspection[]
  opportunities        Opportunity[]
  bidPackages          BidPackage[]
  timeEntries          TimeEntry[]
  subInvoices          SubInvoice[]
  warrantyItems        WarrantyItem[]
  purchaseOrders       PurchaseOrder[]
  permits              Permit[]
  journalEntries       JournalEntryRow[]
  pnlSnapshot          ProjectPnlSnapshot?
  invoiceInboxMessages InvoiceInboxMessage[]
  revenueProjections   RevenueProjection[]
  alertEvents          AlertEvent[]
  historicalImports    HistoricalImport[]
  drawings             Drawing[]
  photos               ProjectPhoto[]
  photoAlbums          ProjectPhotoAlbum[]
  scheduleBaselines    ScheduleBaseline[]
  lookAheads           LookAheadCommitment[]
  cashFlowForecasts    CashFlowForecast[]
  fleetAssignments     FleetAssignment[]
  toolboxTalks         SafetyToolboxTalk[]
  jhas                 JobHazardAnalysis[]
  safetyObservations   SafetyObservation[]
  ncrs                 NonConformanceReport[]
  closeoutPackage      CloseoutPackage?
  capitalPrograms      CapitalProgramProject[]
  bonds                CompanyBond[]
  complianceLinks      ProjectComplianceLink[]
  specSections         SpecSection[]
  jobRequisitions      JobRequisition[]
  crewAssignments      CrewAssignment[]
  placements           Placement[]

  @@unique([tenantId, code])
}

model Thread {
  id        String        @id @default(cuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  channel   ThreadChannel
  isDefault Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  messages ThreadMessage[]

  @@index([projectId])
}

model ThreadMessage {
  id           String   @id @default(cuid())
  threadId     String
  thread       Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId     String
  author       User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body         String
  decisionFlag Boolean  @default(false)
  pinned       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([threadId])
  @@index([authorId])
  @@index([createdAt])
}

model Task {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    String     @default("Medium")
  dueDate     DateTime?
  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  sourceType  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId])
  @@index([assigneeId])
}

model WorkflowTemplate {
  id         String       @id @default(cuid())
  tenantId   String
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  mode       ProjectMode?
  module     String
  configJson String       @default("{}")
  createdAt  DateTime     @default(now())

  @@index([tenantId])
}

model WorkflowRun {
  id           String         @id @default(cuid())
  projectId    String
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateName String
  module       String
  status       WorkflowStatus @default(DRAFT)
  // entityType + entityId promote the (formerly payloadJson-only)
  // identifier of the underlying entity to first-class columns. Lets
  // findActiveRunFor do an O(log N) index lookup instead of scanning the
  // most-recent 50 rows and parsing JSON. payloadJson stays for any extra
  // metadata callers want to attach.
  entityType   String?
  entityId     String?
  payloadJson  String         @default("{}")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  watchers Watcher[]

  @@index([projectId])
  @@index([projectId, entityType, entityId, status])
}

model Watcher {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workflowRunId String?
  workflowRun   WorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  userId        String?
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel       String
  objectType    String
  objectId      String?
  required      Boolean      @default(false)
  createdAt     DateTime     @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([workflowRunId])
}

model NotificationRule {
  id           String            @id @default(cuid())
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  roleTemplate UserRoleTemplate?
  triggerType  String
  delivery     String
  cadence      String?
  slaHours     Int?
  configJson   String            @default("{}")
  createdAt    DateTime          @default(now())

  @@index([tenantId])
}

model ApprovalRoute {
  id           String            @id @default(cuid())
  projectId    String
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  targetType   String
  targetId     String?
  name         String
  status       WorkflowStatus    @default(DRAFT)
  approverRole UserRoleTemplate?
  stepsJson    String            @default("[]")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([projectId])
}

model EquipmentRecord {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  equipmentCode    String
  description      String
  ownershipType    String
  assignedCrew     String?
  utilizationHours Float?   @default(0)
  status           String   @default("Active")
  createdAt        DateTime @default(now())

  @@index([projectId])
}

/**
 * Tenant-level fleet asset. Distinct from per-project EquipmentRecord
 * (which is the assignment ledger). FleetAsset captures depreciation,
 * internal rental rate, maintenance accrual, and tracks which project
 * the asset is currently committed to via FleetAssignment.
 */
model FleetAsset {
  id                      String    @id @default(cuid())
  tenantId                String
  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  assetTag                String
  description             String
  category                String? // "Excavator", "Crane", "Truck", "Generator"
  serialNumber            String?
  purchaseDate            DateTime?
  purchasePrice           Float?
  salvageValue            Float     @default(0)
  usefulLifeMonths        Int?
  depreciationMethod      String    @default("STRAIGHT_LINE")
  accumulatedDepreciation Float     @default(0)
  // Internal cost-per-hour for charge-back when used on a project.
  internalRateHour        Float?
  internalRateDay         Float?
  internalRateWeek        Float?
  internalRateMonth       Float?
  active                  Boolean   @default(true)
  notes                   String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  assignments FleetAssignment[]
  maintenance FleetMaintenance[]

  @@unique([tenantId, assetTag])
  @@index([tenantId])
}

/**
 * Asset → project commitment with hours tracked. Charges flow to job
 * cost via internalRate × hours. Reverts to "available" when ended.
 */
model FleetAssignment {
  id           String     @id @default(cuid())
  fleetAssetId String
  fleetAsset   FleetAsset @relation(fields: [fleetAssetId], references: [id], onDelete: Cascade)
  projectId    String
  project      Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  startedAt    DateTime
  endedAt      DateTime?
  hoursLogged  Float      @default(0)
  costAccrued  Float      @default(0)
  notes        String?
  createdAt    DateTime   @default(now())

  @@index([fleetAssetId])
  @@index([projectId])
}

/**
 * Maintenance event — preventive (oil change, inspection) or
 * corrective (repair). Drives maintenance accrual + downtime tracking.
 */
model FleetMaintenance {
  id            String     @id @default(cuid())
  fleetAssetId  String
  fleetAsset    FleetAsset @relation(fields: [fleetAssetId], references: [id], onDelete: Cascade)
  kind          String // "PREVENTIVE" | "CORRECTIVE" | "INSPECTION"
  scheduledAt   DateTime?
  completedAt   DateTime?
  cost          Float      @default(0)
  vendorName    String?
  description   String
  hoursDownTime Float      @default(0)
  notes         String?
  createdAt     DateTime   @default(now())

  @@index([fleetAssetId])
}

/**
 * Direct-hire employee record — distinct from User (login) and
 * Membership (tenant role). Used for payroll. Pay rate, tax setup,
 * union local, classification all live here.
 */
model Employee {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String? // optional link to a User row when employee can also log in
  employeeNumber  String
  firstName       String
  lastName        String
  email           String?
  phone           String?
  hireDate        DateTime?
  terminationDate DateTime?
  // Classification
  classification  String? // "JOURNEYMAN_CARPENTER", "LABORER", "PROJECT_MANAGER"
  unionLocal      String?
  craftCode       String? // BLS / DBE craft code
  // Pay
  payType         String    @default("HOURLY") // HOURLY | SALARY | UNION
  baseRate        Float     @default(0)
  fringeRate      Float     @default(0) // hourly fringes for union/prevailing wage
  perDiemRate     Float     @default(0)
  burdenRate      Float     @default(0) // employer taxes + benefits as % of base
  // Tax / withholding setup (high-level; details in payroll system)
  w4Filing        String?
  state           String?
  // Status
  active          Boolean   @default(true)
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  payrollRuns PayrollRunLine[]

  @@unique([tenantId, employeeNumber])
  @@index([tenantId])
}

/**
 * Payroll run header. One run per pay period. Generates lines from
 * approved TimeEntry rows + Employee setup. Status moves CALCULATED →
 * APPROVED → POSTED.
 */
model PayrollRun {
  id                 String   @id @default(cuid())
  tenantId           String
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  runLabel           String
  periodFrom         DateTime
  periodTo           DateTime
  payDate            DateTime
  status             String   @default("CALCULATED")
  totalHours         Float    @default(0)
  totalGross         Float    @default(0)
  totalNet           Float    @default(0)
  totalBurden        Float    @default(0)
  isCertifiedPayroll Boolean  @default(false)
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  lines PayrollRunLine[]

  @@unique([tenantId, runLabel])
  @@index([tenantId])
}

/**
 * Per-employee payroll line within a run. Captures regular/OT/DT
 * hours, gross + fringe + per-diem + burden, and the project + cost
 * code split.
 */
model PayrollRunLine {
  id           String     @id @default(cuid())
  payrollRunId String
  payrollRun   PayrollRun @relation(fields: [payrollRunId], references: [id], onDelete: Cascade)
  employeeId   String
  employee     Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  projectId    String?
  costCode     String?
  regularHours Float      @default(0)
  otHours      Float      @default(0)
  dtHours      Float      @default(0)
  baseRate     Float      @default(0)
  fringeRate   Float      @default(0)
  grossPay     Float      @default(0)
  fringeAmount Float      @default(0)
  perDiem      Float      @default(0)
  burden       Float      @default(0)
  totalCost    Float      @default(0) // gross + fringe + per-diem + burden — what hits job cost
  notes        String?
  createdAt    DateTime   @default(now())

  @@index([payrollRunId])
  @@index([employeeId])
}

/**
 * Certified payroll output — Davis-Bacon WH-347 weekly report. Each
 * row corresponds to one employee on one project for one week. Used
 * to satisfy federal/state prevailing-wage reporting.
 */
model CertifiedPayrollRecord {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId      String?
  weekEnding     DateTime
  employeeId     String?
  employeeName   String
  classification String
  craftCode      String?
  ssnLast4       String? // form WH-347 expects last-4 only
  hoursStRegular Float    @default(0)
  hoursStOt      Float    @default(0)
  rateBase       Float    @default(0)
  rateFringe     Float    @default(0)
  grossPay       Float    @default(0)
  deductions     Float    @default(0)
  netPay         Float    @default(0)
  notes          String?
  createdAt      DateTime @default(now())

  @@index([tenantId, weekEnding])
}

/**
 * Annual 1099-NEC reporting per vendor. Aggregates the year's payments
 * by 1099 box for tax filing. Status FILED on submission.
 */
model Vendor1099Record {
  id                      String    @id @default(cuid())
  tenantId                String
  tenant                  Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendorId                String
  vendor                  Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  taxYear                 Int
  recipientTin            String?
  box1NonemployeeComp     Float     @default(0)
  box4FedTaxWithheld      Float     @default(0)
  box6PaymentsForServices Float     @default(0)
  totalPaid               Float     @default(0)
  status                  String    @default("DRAFT") // DRAFT | FILED
  filedAt                 DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@unique([tenantId, vendorId, taxYear])
  @@index([tenantId, taxYear])
}

model MaterialRecord {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  materialType String
  quantity     Float
  unit         String
  status       String   @default("Received")
  source       String?
  locationTag  String?
  createdAt    DateTime @default(now())

  @@index([projectId])
}

model HistoricalEstimate {
  id             String      @id @default(cuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mode           ProjectMode
  title          String
  projectType    String?
  geography      String?
  lineItemCode   String?
  unitCost       Float?
  productionRate Float?
  confidencePct  Int?
  metadataJson   String      @default("{}")
  createdAt      DateTime    @default(now())

  @@index([tenantId])
}

model Document {
  id            String        @id @default(cuid())
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String
  documentClass DocumentClass
  folderPath    String?
  versionLabel  String        @default("v1")
  metadataJson  String        @default("{}")
  // Lifecycle tracking — when this document expires (insurance certs,
  // permits, prequalifications) and when it should be archived.
  // Cron scans documents nearing expiry (60d) and emits AlertEvent.
  effectiveAt   DateTime?
  expiresAt     DateTime?
  archivedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  transmittals DocumentTransmittal[]

  @@index([projectId])
  @@index([expiresAt])
}

/**
 * Transmittal log — formal record of who received which version of
 * which document, when, and via what channel. Required for any
 * litigation-resilient document control program.
 */
model DocumentTransmittal {
  id               String    @id @default(cuid())
  tenantId         String
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documentId       String
  document         Document  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  transmittalNo    String
  recipientName    String
  recipientEmail   String?
  recipientCompany String?
  versionLabel     String
  channel          String    @default("EMAIL")
  notes            String?
  sentAt           DateTime  @default(now())
  acknowledgedAt   DateTime?
  acknowledgedBy   String?
  createdAt        DateTime  @default(now())

  @@unique([tenantId, transmittalNo])
  @@index([documentId])
  @@index([tenantId, sentAt])
}

model RFI {
  id                   String         @id @default(cuid())
  projectId            String
  project              Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number               String
  subject              String
  question             String?
  response             String?
  status               WorkflowStatus @default(DRAFT)
  dueDate              DateTime?
  ballInCourt          String?
  // Reviewer chain — current step in the routing sequence. Sequential
  // routing: each reviewer must respond before the RFI moves to the
  // next. Response SLA aging tracked from sentToReviewerAt.
  currentReviewerEmail String?
  sentToReviewerAt     DateTime?
  // Cost & schedule impact captured during response. Cost is an
  // estimate the architect / engineer can attach; the eventual change
  // order picks this up.
  costImpactCents      Int?
  scheduleImpactDays   Int?
  // Drawing pin reference for spatial context; one RFI can pin to N
  // drawing sheets (see RfiDrawingPin below).
  submittedAt          DateTime?
  submittedBy          String?
  respondedAt          DateTime?
  respondedBy          String?
  approvedAt           DateTime?
  approvedBy           String?
  rejectedAt           DateTime?
  rejectedBy           String?
  rejectionReason      String?
  approvalNote         String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  reviewers          RfiReviewer[]
  responses          RfiResponse[]
  drawingPins        RfiDrawingPin[]
  linkedChangeOrders ChangeOrder[]          @relation("RfiLinkedChangeOrders")
  linkedNcrs         NonConformanceReport[] @relation("RfiLinkedNcrs")

  @@unique([projectId, number])
  @@index([projectId])
}

model Submittal {
  id                    String         @id @default(cuid())
  projectId             String
  project               Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number                String
  title                 String
  specSection           String?
  status                WorkflowStatus @default(DRAFT)
  longLead              Boolean        @default(false)
  // Resubmittal tracking — every reject increments resubmittalCount;
  // status flips back to DRAFT and the row remains so the history is
  // preserved.
  resubmittalCount      Int            @default(0)
  // Reviewer routing — sequential chain via SubmittalReviewer rows.
  currentReviewerEmail  String?
  sentToReviewerAt      DateTime?
  scheduleFloatDaysUsed Int? // float consumed waiting on review
  submittedAt           DateTime?
  submittedBy           String?
  approvedAt            DateTime?
  approvedBy            String?
  rejectedAt            DateTime?
  rejectedBy            String?
  rejectionReason       String?
  approvalNote          String?
  notes                 String?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  reviewers          SubmittalReviewer[]
  cycles             SubmittalCycle[]
  linkedChangeOrders ChangeOrder[]       @relation("SubmittalLinkedChangeOrders")

  @@unique([projectId, number])
  @@index([projectId])
}

/**
 * One reviewer in an RFI's sequential routing chain. Each reviewer
 * gets the RFI in turn; when they respond/approve, the next reviewer
 * is notified. holdReason captures why a reviewer paused the chain.
 */
model RfiReviewer {
  id            String    @id @default(cuid())
  rfiId         String
  rfi           RFI       @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  position      Int
  reviewerEmail String
  reviewerName  String?
  reviewerRole  String? // e.g. "Architect", "Structural Engineer"
  isRequired    Boolean   @default(true)
  decidedAt     DateTime?
  decision      String? // "APPROVED" | "REJECTED" | "HELD"
  holdReason    String?
  responseText  String?
  createdAt     DateTime  @default(now())

  @@unique([rfiId, position])
  @@index([rfiId])
}

/**
 * Every response added to an RFI — the RFI body holds the latest, but
 * the history is in this table for audit and to render a thread.
 */
model RfiResponse {
  id            String   @id @default(cuid())
  rfiId         String
  rfi           RFI      @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  respondedBy   String
  respondedAt   DateTime @default(now())
  responseText  String
  attachmentUrl String?
  createdAt     DateTime @default(now())

  @@index([rfiId])
}

/**
 * Spatial context — pins one RFI to one or more drawing sheets at
 * specific coordinates. Mature platforms (Procore, ACC) treat the
 * drawing sheet as the index; this is the bridge.
 */
model RfiDrawingPin {
  id             String       @id @default(cuid())
  rfiId          String
  rfi            RFI          @relation(fields: [rfiId], references: [id], onDelete: Cascade)
  drawingSheetId String
  drawingSheet   DrawingSheet @relation(fields: [drawingSheetId], references: [id], onDelete: Cascade)
  xRatio         Float // 0..1 normalized within the sheet
  yRatio         Float
  note           String?
  createdAt      DateTime     @default(now())

  @@index([rfiId])
  @@index([drawingSheetId])
}

/**
 * Submittal reviewer chain — analogous to RfiReviewer. Each reviewer
 * gets the submittal in sequence; rejection increments resubmittal
 * count and the cycle starts over with a new SubmittalCycle row.
 */
model SubmittalReviewer {
  id            String    @id @default(cuid())
  submittalId   String
  submittal     Submittal @relation(fields: [submittalId], references: [id], onDelete: Cascade)
  position      Int
  reviewerEmail String
  reviewerName  String?
  reviewerRole  String?
  isRequired    Boolean   @default(true)
  decidedAt     DateTime?
  decision      String?
  holdReason    String?
  responseText  String?
  createdAt     DateTime  @default(now())

  @@unique([submittalId, position])
  @@index([submittalId])
}

/**
 * Each submittal can have multiple revision cycles. Each cycle
 * captures who submitted what version when, and the resulting
 * decision. Lets a project audit "we resubmitted this 4 times because
 * the architect kept rejecting it."
 */
model SubmittalCycle {
  id            String    @id @default(cuid())
  submittalId   String
  submittal     Submittal @relation(fields: [submittalId], references: [id], onDelete: Cascade)
  cycleNumber   Int
  submittedAt   DateTime?
  submittedBy   String?
  decidedAt     DateTime?
  decision      String? // "APPROVED" | "APPROVED_AS_NOTED" | "REVISE_AND_RESUBMIT" | "REJECTED"
  decidedBy     String?
  holdReason    String?
  responseText  String?
  attachmentUrl String?
  createdAt     DateTime  @default(now())

  @@unique([submittalId, cycleNumber])
  @@index([submittalId])
}

model Meeting {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  meetingType String
  scheduledAt DateTime
  notes       String?
  createdAt   DateTime @default(now())

  @@index([projectId])
}

model DailyLog {
  id        String       @id @default(cuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  logDate   DateTime
  logType   DailyLogType @default(GENERAL)
  weather   String?
  summary   String
  manpower  Int          @default(0)
  notes     String?
  // Geotagging (req §7.24): heavy-civil and field workflows need
  // station/segment + lat/lon so daily logs can be plotted on a map
  // and associated with utility runs / road segments.
  segment   String?
  station   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime     @default(now())

  productionEntries ProductionEntry[]
  crewAssignments   CrewAssignment[]

  @@index([projectId, createdAt])
}

model Budget {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  originalValue Float
  currentValue  Float
  forecastFinal Float?
  createdAt     DateTime @default(now())

  lines BudgetLine[]

  @@index([projectId])
}

model BudgetLine {
  id            String         @id @default(cuid())
  budgetId      String
  budget        Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  code          String
  description   String
  lineType      BudgetLineType
  budgetAmount  Float
  committedCost Float          @default(0)
  actualCost    Float          @default(0)
  createdAt     DateTime       @default(now())

  @@index([budgetId])
}

model QuantityBudget {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code         String
  description  String
  unit         String
  budgetQty    Float
  installedQty Float    @default(0)
  earnedQty    Float    @default(0)
  locationTag  String?
  createdAt    DateTime @default(now())

  @@index([projectId])
}

model ProductionEntry {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dailyLogId     String?
  dailyLog       DailyLog? @relation(fields: [dailyLogId], references: [id], onDelete: SetNull)
  activity       String
  crewName       String?
  installedQty   Float     @default(0)
  unit           String?
  productionRate Float?
  equipmentHours Float?
  locationTag    String?
  createdAt      DateTime  @default(now())

  @@index([projectId, createdAt])
  @@index([dailyLogId])
}

model Ticket {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ticketNumber String
  materialType String
  quantity     Float
  unit         String
  source       String?
  destination  String?
  createdAt    DateTime @default(now())

  @@unique([projectId, ticketNumber])
  @@index([projectId])
}

model SafetyIncident {
  id                  String         @id @default(cuid())
  projectId           String
  project             Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title               String
  severity            String
  description         String?
  status              WorkflowStatus @default(DRAFT)
  occurredAt          DateTime
  submittedAt         DateTime?
  submittedBy         String?
  approvedAt          DateTime?
  approvedBy          String?
  rejectedAt          DateTime?
  rejectedBy          String?
  rejectionReason     String?
  approvalNote        String?
  correctiveActions   String?
  // Geotagging (req §7.24): safety reporting often needs precise location
  // for OSHA filings and trend mapping by area / station / utility run.
  segment             String?
  station             String?
  latitude            Float?
  longitude           Float?
  // OSHA classification — ties into the 300/300A/301 export.
  oshaClassification  String? // RECORDABLE | LOST_TIME | NEAR_MISS | FIRST_AID
  bodyPart            String?
  injuryNature        String?
  rootCauseTreeJson   String? // 5-whys / fishbone analysis
  daysAwayCount       Int            @default(0)
  daysRestrictedCount Int            @default(0)
  oshaCaseNumber      String?
  reportedToOshaAt    DateTime?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime?      @updatedAt

  @@index([projectId])
}

/**
 * Toolbox talk / safety-meeting record. Captures attendees + topic
 * for compliance + trend reporting. Each project records weekly toolbox
 * talks; OSHA may request these on inspection.
 */
model SafetyToolboxTalk {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  topic         String
  conductedAt   DateTime
  conductedBy   String?
  attendeesJson String   @default("[]") // [{name, signature?}]
  contentText   String?
  attachmentUrl String?
  createdAt     DateTime @default(now())

  @@index([projectId, conductedAt])
}

/**
 * Job hazard analysis (JHA) / pre-task plan. Required before high-risk
 * work. Steps + hazards + controls. Sign-off list captures everyone
 * who reviewed it before the work started.
 */
model JobHazardAnalysis {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  taskDescription String?
  preparedBy      String?
  reviewedBy      String?
  approvedAt      DateTime?
  approvedBy      String?
  stepsJson       String    @default("[]") // [{step, hazard, control}]
  signOffsJson    String    @default("[]") // [{name, signedAt}]
  validFrom       DateTime?
  validTo         DateTime?
  attachmentUrl   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([projectId])
}

/**
 * Safety observation — proactive near-miss / hazard report (BBS).
 * Drives leading indicator metrics: observation rate, % positive,
 * trend by area / trade.
 */
model SafetyObservation {
  id               String    @id @default(cuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  observerName     String?
  observedAt       DateTime  @default(now())
  category         String // "POSITIVE" | "AT_RISK" | "NEAR_MISS"
  area             String?
  trade            String?
  description      String
  correctiveAction String?
  followUpNeeded   Boolean   @default(false)
  followUpClosedAt DateTime?
  attachmentUrl    String?
  createdAt        DateTime  @default(now())

  @@index([projectId, observedAt])
}

model PunchItem {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  area            String?
  description     String?
  trade           String?
  assignedTo      String?
  status          WorkflowStatus @default(DRAFT)
  dueDate         DateTime?
  closedAt        DateTime?
  closedBy        String?
  submittedAt     DateTime?
  submittedBy     String?
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?
  approvalNote    String?
  // Geotagging (req §7.24): punch items frequently reference a specific
  // location on site; stored alongside `area` (which is a free-text label).
  segment         String?
  station         String?
  latitude        Float?
  longitude       Float?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime?      @updatedAt

  @@index([projectId])
}

model Approval {
  id         String         @id @default(cuid())
  // Pass-10: previously had no tenantId; backup.findMany({}) was leaking
  // approvals across tenants. Now tenant-scoped at write time by
  // workflow.recordWorkflowDecision and read-scoped by backup + any
  // future Approvals admin UI.
  tenantId   String
  approverId String
  approver   User           @relation("ApprovalApprover", fields: [approverId], references: [id], onDelete: Cascade)
  targetType String
  targetId   String
  status     WorkflowStatus @default(DRAFT)
  createdAt  DateTime       @default(now())

  @@index([approverId])
  @@index([tenantId, targetType, targetId])
}

model AuditEvent {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  entityType String
  entityId   String
  action     String
  beforeJson String?
  afterJson  String?
  source     String?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([actorId])
}

model ChangeOrder {
  id                  String            @id @default(cuid())
  projectId           String
  project             Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  coNumber            String
  kind                ChangeOrderKind   @default(PCO)
  title               String
  description         String?
  reason              String?
  amount              Decimal           @default(0)
  markupPct           Float             @default(0)
  scheduleImpactDays  Int               @default(0)
  status              ChangeOrderStatus @default(DRAFT)
  requestedById       String?
  approvedById        String?
  requestedAt         DateTime?
  approvedAt          DateTime?
  submittedBy         String?
  approvedBy          String?
  rejectedAt          DateTime?
  rejectedBy          String?
  rejectionReason     String?
  approvalNote        String?
  executedAt          DateTime?
  // Linked source records — when an RFI response or submittal review
  // prompts the CO. Optional + SetNull on parent delete so the CO
  // record survives as an independent audit trail.
  linkedRfiId         String?
  linkedRfi           RFI?              @relation("RfiLinkedChangeOrders", fields: [linkedRfiId], references: [id], onDelete: SetNull)
  linkedSubmittalId   String?
  linkedSubmittal     Submittal?        @relation("SubmittalLinkedChangeOrders", fields: [linkedSubmittalId], references: [id], onDelete: SetNull)
  // Sub CO carry-down — when an owner CO is approved, child sub COs
  // are auto-created against the affected sub contracts. This field
  // is null on owner-tier COs and set on sub-tier ones to reference
  // the parent.
  parentChangeOrderId String?
  parentChangeOrder   ChangeOrder?      @relation("ChangeOrderParent", fields: [parentChangeOrderId], references: [id], onDelete: SetNull)
  childChangeOrders   ChangeOrder[]     @relation("ChangeOrderParent")
  // Vendor reference for sub CO. Null on owner COs; set when the
  // sub is the counterparty.
  vendorId            String?
  vendor              Vendor?           @relation(fields: [vendorId], references: [id], onDelete: SetNull)
  // Dollar split — captures labor / material / equipment for proper
  // job-cost allocation. Sum should match `amount` after markup.
  laborAmount         Decimal           @default(0)
  materialAmount      Decimal           @default(0)
  equipmentAmount     Decimal           @default(0)
  subAmount           Decimal           @default(0)
  ohpAmount           Decimal           @default(0) // overhead+profit
  lines               ChangeOrderLine[]
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([projectId, coNumber])
  @@index([projectId, status])
  @@index([parentChangeOrderId])
  @@index([vendorId])
}

model ChangeOrderLine {
  id            String      @id @default(cuid())
  changeOrderId String
  changeOrder   ChangeOrder @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)
  costCode      String?
  description   String
  category      String      @default("LABOR")
  quantity      Float       @default(1)
  unit          String?
  unitCost      Decimal     @default(0)
  amount        Decimal     @default(0)
  createdAt     DateTime    @default(now())

  @@index([changeOrderId])
}

model ScheduleTask {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentId        String?
  parent          ScheduleTask?  @relation("ScheduleTaskParent", fields: [parentId], references: [id], onDelete: SetNull)
  children        ScheduleTask[] @relation("ScheduleTaskParent")
  wbs             String?
  name            String
  startDate       DateTime
  endDate         DateTime
  durationDays    Float          @default(1)
  percentComplete Float          @default(0)
  isMilestone     Boolean        @default(false)
  onCriticalPath  Boolean        @default(false)
  baselineStart   DateTime?
  baselineEnd     DateTime?
  actualStart     DateTime?
  actualEnd       DateTime?
  responsible     String?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  predecessors ScheduleDependency[]  @relation("ScheduleDepSuccessor")
  successors   ScheduleDependency[]  @relation("ScheduleDepPredecessor")
  lookAheads   LookAheadCommitment[]

  @@index([projectId])
  @@index([parentId])
}

/**
 * A frozen schedule snapshot. Saved at baseline ("ISSUE FOR
 * CONSTRUCTION") and any contract-significant rebaseline event.
 * Drives variance reports — current activity dates compared against
 * the baseline at the same WBS code.
 */
model ScheduleBaseline {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label       String
  capturedAt  DateTime @default(now())
  capturedBy  String?
  reason      String? // "Initial baseline", "Owner-approved CO 7", etc.
  notes       String?
  payloadJson String // serialized snapshot of all ScheduleTasks at capture time
  createdAt   DateTime @default(now())

  @@unique([projectId, label])
  @@index([projectId])
}

/**
 * Look-ahead pull-plan commitments — what's scheduled to happen in
 * the next N weeks per crew/sub. Each commitment has a planned vs
 * actual completion + a percent-plan-complete (PPC) measure.
 */
model LookAheadCommitment {
  id                String        @id @default(cuid())
  projectId         String
  project           Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  scheduleTaskId    String?
  scheduleTask      ScheduleTask? @relation(fields: [scheduleTaskId], references: [id], onDelete: SetNull)
  weekStarting      DateTime
  description       String
  responsibleParty  String
  plannedComplete   Boolean       @default(false)
  actualComplete    Boolean       @default(false)
  reasonNotComplete String? // standard last-planner reason codes
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  @@index([projectId, weekStarting])
}

/**
 * Hierarchical cost code library — the chart of accounts for a
 * construction project. Tenant-scoped so each company can pick its
 * own structure (CSI MasterFormat 16-division, 50-division, or
 * custom). Used by BudgetLine, PayApplicationLine, JournalEntryRow,
 * ChangeOrderLine to roll up costs by division/discipline.
 */
model CostCode {
  id          String     @id @default(cuid())
  tenantId    String
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      CostCode?  @relation("CostCodeParent", fields: [parentId], references: [id], onDelete: SetNull)
  children    CostCode[] @relation("CostCodeParent")
  code        String // "03", "03 30 00", "03-310-100"
  name        String // "Concrete", "Cast-in-Place Concrete", "Foundations"
  description String?
  csiDivision String? // "03"
  csiSection  String? // "03 30 00"
  level       Int        @default(0) // depth for tree rendering
  active      Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId, parentId])
  @@index([tenantId, csiDivision])
}

/**
 * Vendor prequalification record — formal qualification questionnaire
 * with scoring. Each tenant has its own qual criteria; the form
 * captures financial strength, safety record, bonding, references,
 * and a calculated score that drives "qualified for jobs $X-$Y."
 */
model VendorPrequalification {
  id                  String    @id @default(cuid())
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  vendorId            String
  vendor              Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  formVersion         String    @default("v1")
  status              String    @default("PENDING") // PENDING | APPROVED | REJECTED | EXPIRED
  // Financial data the prequal collects.
  yearsInBusiness     Int?
  annualRevenue       Float?
  largestProjectValue Float?
  bondingCapacity     Float?
  bondingAggregate    Float?
  emrRate             Float? // experience modification rate (safety)
  // Insurance + license summary (the actual records live in InsuranceCert + ContractorLicense).
  insuranceVerified   Boolean   @default(false)
  licenseVerified     Boolean   @default(false)
  workersCompCarrier  String?
  glLimitMillions     Float?
  // Scoring + decision.
  score               Float?
  scoreBreakdownJson  String    @default("{}")
  qualifiedFromValue  Float?
  qualifiedToValue    Float?
  qualifiedTrades     String    @default("[]")
  expiresAt           DateTime?
  approvedAt          DateTime?
  approvedBy          String?
  rejectedAt          DateTime?
  rejectedBy          String?
  rejectionReason     String?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  references VendorReference[]

  @@unique([tenantId, vendorId, formVersion])
  @@index([tenantId])
  @@index([vendorId])
  @@index([expiresAt])
}

/**
 * Public-API token. Each token belongs to a tenant; calls authenticate
 * with `Authorization: Bearer <prefix>.<secret>`. Only the secret hash
 * is stored. Optional scope list controls which endpoints the token
 * can hit ("read:projects", "write:rfis").
 */
model ApiToken {
  id          String    @id @default(cuid())
  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  prefix      String    @unique
  secretHash  String
  scopesJson  String    @default("[]")
  createdById String?
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId])
}

/**
 * Outbound webhook subscription. When events fire on the platform
 * (rfi.created, listing.scored, payapp.approved), the dispatcher
 * POSTs the event JSON to every active endpoint subscribed to the
 * matching event type.
 */
model WebhookEndpoint {
  id             String    @id @default(cuid())
  tenantId       String
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  url            String
  secret         String // shared secret for HMAC signature
  eventsJson     String    @default("[]") // ["rfi.created","payapp.approved", "*"]
  active         Boolean   @default(true)
  lastDeliveryAt DateTime?
  lastSuccessAt  DateTime?
  failureCount   Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  deliveries WebhookDelivery[]

  @@index([tenantId])
}

/**
 * Single delivery attempt log — for debugging webhook integrations.
 */
model WebhookDelivery {
  id           String          @id @default(cuid())
  endpointId   String
  endpoint     WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  eventType    String
  payloadJson  String
  responseCode Int?
  responseBody String?
  durationMs   Int?
  succeeded    Boolean         @default(false)
  createdAt    DateTime        @default(now())

  @@index([endpointId, createdAt])
}

/**
 * Free guest account — owner / architect / inspector / sub. Read-only
 * access to a specific project (or set of resources) via magic link.
 * Lets the GC bring outside collaborators in without a paid seat.
 */
model GuestAccount {
  id                  String    @id @default(cuid())
  tenantId            String
  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email               String
  name                String?
  role                String    @default("OWNER_REVIEWER") // OWNER_REVIEWER | ARCHITECT | INSPECTOR | SUB
  scopeJson           String    @default("{}") // {projectIds:[…], allowRespond:true}
  magicTokenHash      String?
  magicTokenExpiresAt DateTime?
  lastSeenAt          DateTime?
  active              Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId])
}

/**
 * Tenant-level email digest subscription. The /api/cron/email-digest
 * route reads these and sends rolled-up summaries (daily / weekly).
 */
model EmailDigest {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  recipient    String
  cadence      String    @default("WEEKLY") // DAILY | WEEKLY
  sectionsJson String    @default("[]") // ["rfi","payapp","alerts","listings"]
  active       Boolean   @default(true)
  lastSentAt   DateTime?
  createdAt    DateTime  @default(now())

  @@unique([tenantId, recipient, cadence])
  @@index([tenantId])
}

/**
 * Reference contact provided during prequalification (former GC, owner,
 * supplier). Reference checks recorded on calledAt + outcomeNotes.
 */
model VendorReference {
  id            String                 @id @default(cuid())
  prequalId     String
  prequal       VendorPrequalification @relation(fields: [prequalId], references: [id], onDelete: Cascade)
  contactName   String
  company       String
  email         String?
  phone         String?
  relationship  String?
  calledAt      DateTime?
  outcomeRating Int? // 1-5
  outcomeNotes  String?
  createdAt     DateTime               @default(now())

  @@index([prequalId])
}

model ScheduleDependency {
  id            String                 @id @default(cuid())
  predecessorId String
  predecessor   ScheduleTask           @relation("ScheduleDepPredecessor", fields: [predecessorId], references: [id], onDelete: Cascade)
  successorId   String
  successor     ScheduleTask           @relation("ScheduleDepSuccessor", fields: [successorId], references: [id], onDelete: Cascade)
  type          ScheduleDependencyType @default(FS)
  lagDays       Float                  @default(0)
  createdAt     DateTime               @default(now())

  @@unique([predecessorId, successorId])
  @@index([predecessorId])
  @@index([successorId])
}

model Contract {
  id              String               @id @default(cuid())
  projectId       String
  project         Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  counterparty    String
  contractNumber  String
  title           String
  type            ContractType
  status          ContractStatus       @default(DRAFT)
  originalValue   Decimal              @default(0)
  currentValue    Decimal              @default(0)
  retainagePct    Float                @default(10)
  startDate       DateTime?
  endDate         DateTime?
  executedAt      DateTime?
  executedBy      String?
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?
  approvalNote    String?
  notes           String?
  commitments     ContractCommitment[]
  payApplications PayApplication[]
  lienWaivers     LienWaiver[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@unique([projectId, contractNumber])
  @@index([projectId, status])
}

model ContractCommitment {
  id              String   @id @default(cuid())
  contractId      String
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  costCode        String?
  description     String
  scope           String?
  committedAmount Decimal  @default(0)
  invoicedToDate  Decimal  @default(0)
  paidToDate      Decimal  @default(0)
  createdAt       DateTime @default(now())

  @@index([contractId])
}

model PayApplication {
  id                    String               @id @default(cuid())
  projectId             String
  project               Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractId            String?
  contract              Contract?            @relation(fields: [contractId], references: [id], onDelete: SetNull)
  periodNumber          Int
  periodFrom            DateTime
  periodTo              DateTime
  status                PayApplicationStatus @default(DRAFT)
  originalContractValue Decimal              @default(0)
  changeOrderValue      Decimal              @default(0)
  totalContractValue    Decimal              @default(0)
  workCompletedToDate   Decimal              @default(0)
  materialsStoredToDate Decimal              @default(0)
  retainagePct          Float                @default(10)
  retainageHeld         Decimal              @default(0)
  lessPreviousPayments  Decimal              @default(0)
  currentPaymentDue     Decimal              @default(0)
  submittedAt           DateTime?
  submittedBy           String?
  approvedAt            DateTime?
  approvedBy            String?
  rejectedAt            DateTime?
  rejectedBy            String?
  rejectionReason       String?
  approvalNote          String?
  paidAt                DateTime?
  paidBy                String?
  notes                 String?
  lines                 PayApplicationLine[]
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@unique([projectId, periodNumber])
  @@index([projectId, status])
  @@index([contractId])
}

model PayApplicationLine {
  id                String         @id @default(cuid())
  payApplicationId  String
  payApplication    PayApplication @relation(fields: [payApplicationId], references: [id], onDelete: Cascade)
  lineNumber        Int
  costCode          String?
  description       String
  scheduledValue    Decimal        @default(0)
  workCompletedPrev Decimal        @default(0)
  workCompletedThis Decimal        @default(0)
  materialsStored   Decimal        @default(0)
  totalCompleted    Decimal        @default(0)
  percentComplete   Float          @default(0)
  balanceToFinish   Decimal        @default(0)
  retainage         Decimal        @default(0)
  createdAt         DateTime       @default(now())

  @@unique([payApplicationId, lineNumber])
  @@index([payApplicationId])
}

model LienWaiver {
  id                 String           @id @default(cuid())
  projectId          String
  project            Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contractId         String?
  contract           Contract?        @relation(fields: [contractId], references: [id], onDelete: SetNull)
  waiverType         LienWaiverType
  partyName          String
  throughDate        DateTime
  amount             Decimal          @default(0)
  status             LienWaiverStatus @default(PENDING)
  receivedAt         DateTime?
  receivedBy         String?
  approvedAt         DateTime?
  approvedBy         String?
  rejectedAt         DateTime?
  rejectedBy         String?
  rejectionReason    String?
  approvalNote       String?
  documentUrl        String?
  notes              String?
  // Sub-tier waiver chain — when a sub's lower-tier suppliers /
  // sub-subs file their own waivers, they link upward via
  // parentWaiverId. The pay app to the sub releases only when this
  // chain is complete.
  parentWaiverId     String?
  parentWaiver       LienWaiver?      @relation("LienWaiverChain", fields: [parentWaiverId], references: [id], onDelete: SetNull)
  childWaivers       LienWaiver[]     @relation("LienWaiverChain")
  // Reference to the sub invoice this waiver covers — drives the
  // conditional release logic ("don't pay until matching waiver
  // received").
  subInvoiceId       String?
  subInvoice         SubInvoice?      @relation("LienWaiverSubInvoice", fields: [subInvoiceId], references: [id], onDelete: SetNull)
  // State-specific compliance — some states require notarization or
  // a specific statutory form. Capture which statute the waiver was
  // produced under.
  statutoryFormState String? // "FL", "TX", "CA"
  notarized          Boolean          @default(false)
  notarizedAt        DateTime?
  notaryName         String?
  // Generation source — manual upload vs auto-generated by the
  // platform. Auto-generation produces conditional waivers attached
  // to pay-app submission and unconditional waivers attached to
  // payment receipt.
  generationSource   String           @default("UPLOADED") // UPLOADED | AUTO_GENERATED
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([projectId])
  @@index([contractId])
  @@index([subInvoiceId])
  @@index([parentWaiverId])
}

model Inspection {
  id             String           @id @default(cuid())
  projectId      String
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  permitId       String?
  permit         Permit?          @relation("PermitInspections", fields: [permitId], references: [id], onDelete: SetNull)
  kind           InspectionKind
  title          String
  scheduledAt    DateTime?
  completedAt    DateTime?
  inspector      String?
  location       String?
  result         InspectionResult @default(PENDING)
  followUpNeeded Boolean          @default(false)
  followUpNotes  String?
  checklistJson  String           @default("[]")
  externalId     String?
  sourceSystem   String?
  syncedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  checklistItems InspectionChecklistItem[]
  attachments    InspectionAttachment[]
  ncrs           NonConformanceReport[]

  @@index([projectId])
  @@index([permitId])
}

/**
 * Quality checklist template — a reusable inspection form per trade.
 * Owners typically require signed checklists before pour, dry-in,
 * substantial completion, etc. Tenant-scoped so each company can
 * maintain its own templates.
 */
model QualityChecklistTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String // "Concrete Pour Pre-Pour Checklist"
  trade     String?
  itemsJson String   @default("[]") // [{title, codeReference, requirement}]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
}

/**
 * Non-conformance report — defect found that doesn't meet spec.
 * Captures category, severity, photos, root cause, and disposition
 * (REWORK / USE_AS_IS / SCRAP / REPAIR). Auto-creates a corresponding
 * RFI when disposition needs designer input.
 */
model NonConformanceReport {
  id                 String      @id @default(cuid())
  projectId          String
  project            Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inspectionId       String?
  inspection         Inspection? @relation(fields: [inspectionId], references: [id], onDelete: SetNull)
  ncrNumber          String
  title              String
  category           String? // "DIMENSIONAL" | "MATERIAL" | "WORKMANSHIP" | "DOCUMENTATION"
  severity           String      @default("MAJOR") // MINOR | MAJOR | CRITICAL
  description        String
  rootCause          String?
  disposition        String? // REWORK | USE_AS_IS | SCRAP | REPAIR | RETURN_TO_VENDOR
  correctiveAction   String?
  preventiveAction   String?
  attachmentUrl      String?
  raisedById         String?
  raisedAt           DateTime    @default(now())
  closedAt           DateTime?
  closedBy           String?
  costImpact         Float       @default(0)
  scheduleImpactDays Int         @default(0)
  linkedRfiId        String?
  linkedRfi          RFI?        @relation("RfiLinkedNcrs", fields: [linkedRfiId], references: [id], onDelete: SetNull)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@unique([projectId, ncrNumber])
  @@index([projectId])
}

/**
 * Closeout package — collection of warranty/O&M/as-built/lien-waiver
 * docs assembled for owner handover. Status moves DRAFT → IN_REVIEW →
 * APPROVED → DELIVERED. Tracks completeness percentage from a
 * checklist of required deliverables.
 */
model CloseoutPackage {
  id                String    @id @default(cuid())
  projectId         String    @unique
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  status            String    @default("DRAFT")
  checklistJson     String    @default("[]") // [{label, complete, evidenceUrl?}]
  completionPct     Float     @default(0)
  ownerAcceptedAt   DateTime?
  ownerAcceptedBy   String?
  punchListClosedAt DateTime?
  warrantyStartAt   DateTime?
  warrantyEndAt     DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([projectId])
}

model Opportunity {
  id             String           @id @default(cuid())
  tenantId       String
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId      String?
  project        Project?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  name           String
  clientName     String?
  stage          OpportunityStage @default(LEAD)
  estimatedValue Float            @default(0)
  probability    Int              @default(20)
  dueDate        DateTime?
  awardDate      DateTime?
  notes          String?
  ownerName      String?
  source         String?
  mode           ProjectMode      @default(VERTICAL)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  rfpListings   RfpListing[]
  bidDrafts     BidDraft[]
  captureRecord CaptureRecord?

  @@index([tenantId])
  @@index([projectId])
}

model Vendor {
  id                 String                 @id @default(cuid())
  tenantId           String
  tenant             Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name               String
  legalName          String?
  trade              String?
  phone              String?
  email              String?
  address            String?
  emrRate            Float?
  ein                String?
  prequalStatus      PrequalificationStatus @default(NOT_STARTED)
  prequalScore       Int?
  prequalExpires     DateTime?
  bondingCapacity    Float?
  defaultCostCode    String?
  defaultAccountCode String?
  createdAt          DateTime               @default(now())
  updatedAt          DateTime               @updatedAt

  insuranceCerts InsuranceCert[]
  subBids        SubBid[]
  subInvoices    SubInvoice[]
  purchaseOrders PurchaseOrder[]
  prequals       VendorPrequalification[]
  changeOrders   ChangeOrder[]
  vendor1099s    Vendor1099Record[]
}

model InsuranceCert {
  id             String        @id @default(cuid())
  vendorId       String
  vendor         Vendor        @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  type           InsuranceType
  carrier        String
  policyNumber   String
  limitEach      Float         @default(0)
  limitAggregate Float         @default(0)
  effectiveDate  DateTime
  expirationDate DateTime
  certificateUrl String?
  createdAt      DateTime      @default(now())
}

model BidPackage {
  id             String           @id @default(cuid())
  projectId      String
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name           String
  trade          String
  scopeSummary   String?
  dueDate        DateTime?
  estimatedValue Float            @default(0)
  status         BidPackageStatus @default(PLANNING)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  subBids         SubBid[]
  levelingResults BidLevelingResult[]

  @@index([projectId, status])
}

model SubBid {
  id                  String       @id @default(cuid())
  bidPackageId        String
  bidPackage          BidPackage   @relation(fields: [bidPackageId], references: [id], onDelete: Cascade)
  vendorId            String
  vendor              Vendor       @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  bidAmount           Float?
  daysToComplete      Int?
  inclusions          String?
  exclusions          String?
  // Bid clarification questions raised by this sub during bidding +
  // overall qualifications/voluntary alternates.
  clarifications      String?
  voluntaryAlternates String?
  status              SubBidStatus @default(INVITED)
  submittedAt         DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  lines         SubBidLine[]
  awardedScopes BidLevelingResult[]

  @@unique([bidPackageId, vendorId])
  @@index([bidPackageId])
  @@index([vendorId])
}

/**
 * Line-item detail in a sub bid — tied to the bid package's scope
 * sheet so multiple subs' lines can be compared apples-to-apples in
 * the leveling matrix. scopeItemKey is shared across all bidders'
 * lines for the same scope item; the leveling UI groups by it.
 */
model SubBidLine {
  id           String   @id @default(cuid())
  subBidId     String
  subBid       SubBid   @relation(fields: [subBidId], references: [id], onDelete: Cascade)
  scopeItemKey String
  description  String
  quantity     Float?
  uom          String?
  unitPrice    Float?
  amount       Float
  costCode     String?
  inclusion    Boolean  @default(true) // false = exclusion
  notes        String?
  createdAt    DateTime @default(now())

  @@index([subBidId])
  @@index([scopeItemKey])
}

/**
 * Bid leveling result — the awarded line allocation across bidders
 * after analysis. Stored so the GC has a record of why each line went
 * to which sub.
 */
model BidLevelingResult {
  id                String     @id @default(cuid())
  bidPackageId      String
  bidPackage        BidPackage @relation(fields: [bidPackageId], references: [id], onDelete: Cascade)
  scopeItemKey      String
  awardedToSubBidId String
  awardedToSubBid   SubBid     @relation(fields: [awardedToSubBidId], references: [id], onDelete: Cascade)
  rationale         String?
  decidedAt         DateTime   @default(now())
  decidedBy         String?

  @@unique([bidPackageId, scopeItemKey])
  @@index([bidPackageId])
}

/**
 * Capital program — multi-project umbrella owned by the customer
 * (private GC's portfolio, public agency's CIP, etc.). Drives owner-
 * dashboard rollups across projects in the program.
 */
model CapitalProgram {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  ownerName     String?
  ownerType     String? // "PRIVATE" | "PUBLIC_AGENCY" | "INSTITUTIONAL"
  totalBudget   Float?
  contingency   Float?
  fundingSource String?
  startDate     DateTime?
  endDate       DateTime?
  status        String    @default("ACTIVE")
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  projects CapitalProgramProject[]

  @@index([tenantId])
}

/**
 * Many-to-many between a capital program and its constituent projects.
 * A project can belong to multiple programs (e.g., a school district
 * lists a project under both "Bond 2024" and "Annual Capital Plan").
 */
model CapitalProgramProject {
  id               String         @id @default(cuid())
  capitalProgramId String
  capitalProgram   CapitalProgram @relation(fields: [capitalProgramId], references: [id], onDelete: Cascade)
  projectId        String
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  programBudget    Float?
  drawSchedule     String?
  notes            String?
  createdAt        DateTime       @default(now())

  @@unique([capitalProgramId, projectId])
  @@index([capitalProgramId])
  @@index([projectId])
}

model TimeEntry {
  id              String          @id @default(cuid())
  projectId       String
