model SubInvoice {
  id              String           @id @default(cuid())
  projectId       String
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendorId        String
  vendor          Vendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  invoiceNumber   String
  description     String?
  amount          Decimal          @default(0)
  retainageHeld   Decimal          @default(0)
  netDue          Decimal          @default(0)
  status          SubInvoiceStatus @default(RECEIVED)
  invoiceDate     DateTime
  dueDate         DateTime?
  submittedAt     DateTime?
  submittedBy     String?
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?
  approvalNote    String?
  paidAt          DateTime?
  paidBy          String?
  waiverReceived  Boolean          @default(false)
  notes           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  // Reference to the GC's purchase order (if any) for 3-way match.
  // The 3-way-match worker compares lines[].amount against
  // PurchaseOrderReceiptLine quantities × PurchaseOrderLine.unitPrice.
  purchaseOrderId    String?
  matchStatus        String  @default("UNMATCHED") // UNMATCHED | MATCHED | VARIANCE | DISPUTED
  matchVarianceCents Int     @default(0)
  // Joint check setup — if true, payment is co-payable to vendor and
  // a third party (typically supplier or surety) and JointCheckParty
  // captures the named co-payee.
  isJointCheck       Boolean @default(false)
  jointPartyName     String?
  jointPartyTaxId    String?
  // Sub default insurance — premium retained from each pay to fund
  // sub-default coverage on this contract.
  subDefaultPremium  Float   @default(0)

  lines   SubInvoiceLine[]
  waivers LienWaiver[]     @relation("LienWaiverSubInvoice")

  @@unique([projectId, invoiceNumber])
  @@index([projectId])
  @@index([vendorId])
  @@index([purchaseOrderId])
}

/**
 * Line-item detail on a sub invoice — required to do 3-way match
 * against PO lines + receipt lines, and to drive G703-style invoice
 * presentation back to the owner.
 */
model SubInvoiceLine {
  id           String     @id @default(cuid())
  subInvoiceId String
  subInvoice   SubInvoice @relation(fields: [subInvoiceId], references: [id], onDelete: Cascade)
  lineNumber   Int
  description  String
  costCode     String?
  quantity     Float?
  unitPrice    Decimal?
  amount       Decimal
  poLineId     String?
  retainage    Decimal    @default(0)
  notes        String?
  createdAt    DateTime   @default(now())

  @@unique([subInvoiceId, lineNumber])
  @@index([subInvoiceId])
}

model PurchaseOrder {
  id               String    @id @default(cuid())
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendorId         String
  vendor           Vendor    @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  poNumber         String
  description      String
  amount           Float     @default(0)
  invoicedToDate   Float     @default(0)
  status           String    @default("OPEN")
  issuedAt         DateTime  @default(now())
  issuedBy         String?
  approvedAt       DateTime?
  approvedBy       String?
  rejectedAt       DateTime?
  rejectedBy       String?
  rejectionReason  String?
  approvalNote     String?
  closedAt         DateTime?
  closedBy         String?
  expectedDelivery DateTime?
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  lines    PurchaseOrderLine[]
  receipts PurchaseOrderReceipt[]

  @@unique([projectId, poNumber])
  @@index([projectId])
  @@index([vendorId])
}

/**
 * One scope line within a purchase order. PO totals are the sum of
 * line amounts (qty × unit price). Receipts and invoices match against
 * lines to enforce 3-way match.
 */
model PurchaseOrderLine {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  lineNumber      Int
  description     String
  costCode        String?
  quantity        Float
  uom             String? // unit of measure
  unitPrice       Float
  amount          Float
  receivedQty     Float         @default(0)
  invoicedQty     Float         @default(0)
  notes           String?
  createdAt       DateTime      @default(now())

  receiptLines PurchaseOrderReceiptLine[]

  @@unique([purchaseOrderId, lineNumber])
  @@index([purchaseOrderId])
}

/**
 * Goods-receipt note. Field signs receipt of materials; the receipt
 * lines tie back to PO lines, which the AP-side invoice matches
 * against (PO line ↔ Receipt line ↔ SubInvoice line). Three-way
 * match flags exceptions when any leg's amount/quantity differs.
 */
model PurchaseOrderReceipt {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  receiptNumber   String
  receivedAt      DateTime
  receivedBy      String?
  carrier         String?
  trackingNumber  String?
  damageNoted     Boolean       @default(false)
  damageNotes     String?
  attachmentUrl   String? // signed delivery ticket
  createdAt       DateTime      @default(now())

  lines PurchaseOrderReceiptLine[]

  @@unique([purchaseOrderId, receiptNumber])
  @@index([purchaseOrderId])
}

model PurchaseOrderReceiptLine {
  id        String               @id @default(cuid())
  receiptId String
  receipt   PurchaseOrderReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  poLineId  String
  poLine    PurchaseOrderLine    @relation(fields: [poLineId], references: [id], onDelete: Cascade)
  quantity  Float
  notes     String?
  createdAt DateTime             @default(now())

  @@index([receiptId])
  @@index([poLineId])
}

model WarrantyItem {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  reportedBy      String?
  assignedTo      String?
  severity        String         @default("NORMAL")
  status          WarrantyStatus @default(OPEN)
  reportedAt      DateTime       @default(now())
  resolvedAt      DateTime?
  resolution      String?
  warrantyExpires DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}

// Permits + per-item inspection checklists + attachments

model Permit {
  id                String                 @id @default(cuid())
  projectId         String
  project           Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  permitType        String
  permitNumber      String
  jurisdiction      String
  jurisdictionUrl   String?
  portalId          String?
  status            PermitStatus           @default(PLANNED)
  appliedAt         DateTime?
  issuedAt          DateTime?
  expiresAt         DateTime?
  finaledAt         DateTime?
  holder            String?
  contractor        String?
  scopeDescription  String?
  fee               Float                  @default(0)
  autoLookupEnabled Boolean                @default(false)
  lastLookupAt      DateTime?
  lastLookupStatus  InspectionLookupStatus @default(NEVER)
  lastLookupNote    String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  inspections Inspection[] @relation("PermitInspections")

  // Prerequisite chain — a permit can require other permits to be
  // issued or finaled before this one can be applied for. Captures
  // typical sequencing like Foundation → Framing → MEP → C of O.
  prerequisites PermitPrerequisite[] @relation("PermitDependent")
  dependents    PermitPrerequisite[] @relation("PermitRequired")

  @@unique([projectId, permitNumber])
  @@index([projectId])
}

/**
 * Permit prerequisite relationship. requiredPermit must reach
 * `requiredStatus` (default ISSUED) before dependentPermit can leave
 * PLANNED. UI reads this to render a blocked-by chip and to compute
 * critical-path delays when a prereq slips.
 */
model PermitPrerequisite {
  id                String       @id @default(cuid())
  dependentPermitId String
  dependentPermit   Permit       @relation("PermitDependent", fields: [dependentPermitId], references: [id], onDelete: Cascade)
  requiredPermitId  String
  requiredPermit    Permit       @relation("PermitRequired", fields: [requiredPermitId], references: [id], onDelete: Cascade)
  requiredStatus    PermitStatus @default(ISSUED)
  notes             String?
  createdAt         DateTime     @default(now())

  @@unique([dependentPermitId, requiredPermitId])
  @@index([dependentPermitId])
  @@index([requiredPermitId])
}

/**
 * Contractor license verification — pulled from state license boards
 * (NMLS, state contractor license verification systems). Surfaced on
 * permit detail to confirm the contractor pulling the permit holds a
 * valid license at this jurisdiction.
 */
model ContractorLicense {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contractorName  String
  licenseNumber   String
  licenseType     String
  jurisdiction    String
  state           String
  issuedAt        DateTime?
  expiresAt       DateTime?
  status          String    @default("UNKNOWN")
  lastVerifiedAt  DateTime?
  verifySourceUrl String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, licenseNumber, jurisdiction])
  @@index([tenantId])
  @@index([expiresAt])
}

model InspectionChecklistItem {
  id            String               @id @default(cuid())
  inspectionId  String
  inspection    Inspection           @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  position      Int
  title         String
  codeReference String?
  status        InspectionItemStatus @default(PENDING)
  notes         String?
  photoUrl      String?
  resolvedAt    DateTime?
  createdAt     DateTime             @default(now())

  @@index([inspectionId])
}

model InspectionAttachment {
  id           String     @id @default(cuid())
  inspectionId String
  inspection   Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  label        String
  url          String
  contentType  String?
  createdAt    DateTime   @default(now())

  @@index([inspectionId])
}

// RFP / bid automation CRM

model RfpSource {
  id                String                     @id @default(cuid())
  tenantId          String
  tenant            Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  label             String
  url               String
  agencyHint        String?
  // Optional pointer to the global SolicitationPortalCatalog row this
  // source was derived from. Lets the UI render "subscribed via the
  // GSA Forecast catalog entry" affordances.
  catalogId         String?
  catalog           SolicitationPortalCatalog? @relation(fields: [catalogId], references: [id], onDelete: SetNull)
  cadence           String                     @default("DAILY")
  naicsFilter       String?
  keywordsJson      String                     @default("[]")
  setAsideFilter    String?
  status            RfpSourceStatus            @default(ACTIVE)
  geoScope          String?
  geoCity           String?
  geoState          String?
  geoCountry        String?                    @default("US")
  authType          String                     @default("NONE")
  authUsername      String?
  authPasswordEnc   String?
  authApiKeyEnc     String?
  authCookieJar     String?
  authNotes         String?
  autoLogin         Boolean                    @default(false)
  // Auto-draft policy. When enabled, listings whose computed score is
  // >= autoDraftMinScore at sweep time skip manual review and run
  // autopilotListing() right away. Default 70 is sensible; the UI
  // exposes per-source overrides.
  autoDraftEnabled  Boolean                    @default(false)
  autoDraftMinScore Int                        @default(70)
  lastAuthAt        DateTime?
  lastCheckedAt     DateTime?
  lastCheckNote     String?
  lastResultCount   Int                        @default(0)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  listings RfpListing[]

  @@index([tenantId])
  @@index([catalogId])
}

enum AgencyKind {
  FEDERAL
  STATE
  COUNTY
  MUNICIPAL
  TRIBAL
  AGGREGATOR
  PRIVATE
  AUTHORITY
}

/// How the platform pulls listings from a portal. Pass-11: replaces the
/// previous deterministic mock crawler. Each portal in the catalog
/// declares its scraperKind and the dispatcher in src/lib/scrapers/
/// index.ts routes accordingly. Portals marked MANUAL are visible in
/// the catalog so operators can find them, but the sweep refuses to
/// fabricate data — operators visit those portals' web UIs directly
/// until a real scraper ships.
enum ScraperKind {
  API
  RSS
  HTML
  MANUAL
  DEPRECATED
}

/// Agency tier — coarse grouping under FEDERAL. Lets the catalog UI
/// render "DoD branches" / "VA centers" / "GSA-wide" categories without
/// hard-coding the entire NAICS taxonomy.
enum AgencyTier {
  CIVILIAN
  DOD
  VA
  USACE
  GSA
  HOMELAND
  ENERGY
  TRANSPORTATION
  HEALTH
  EDUCATION
  INDEPENDENT
  OTHER
}

model SolicitationPortalCatalog {
  id                String      @id @default(cuid())
  name              String
  url               String      @unique
  category          String
  // Structured agency classification (added 2026-05-01) lets the
  // discover UI categorize portals federal vs state vs county vs
  // municipal vs aggregator and surface DoD / VA / GSA sub-tiers.
  agencyKind        AgencyKind  @default(FEDERAL)
  agencyTier        AgencyTier  @default(CIVILIAN)
  agencyName        String?
  geoScope          String
  geoCity           String?
  geoState          String?
  geoCountry        String      @default("US")
  authType          String      @default("NONE")
  signupUrl         String?
  description       String?
  naicsFocus        String?
  setAsideFocus     String?
  // scraperKind names the integration backing this portal. MANUAL means
  // no auto-scraper — operators visit the portal's UI directly. The
  // sweep dispatcher refuses to run MANUAL/DEPRECATED portals so the
  // app never fabricates listings.
  scraperKind       ScraperKind @default(MANUAL)
  // scraperModule names the file under src/lib/scrapers/<name>.ts when
  // scraperKind is API/RSS/HTML. Empty for MANUAL/DEPRECATED.
  scraperModule     String?
  // Verification telemetry — written by scripts/verify-html-scrapers.ts
  // and the periodic sweep cron. lastVerifiedAt is null until the
  // first probe; lastVerifiedOk records the binary outcome;
  // lastVerifiedNote captures the failure mode (e.g., "404", "no
  // tables", "captcha"). Surfaced on the /bids/portal-coverage admin
  // page so ops staff can prioritize portal-scraper backlog.
  lastVerifiedAt    DateTime?
  lastVerifiedOk    Boolean?
  lastVerifiedCount Int?
  lastVerifiedNote  String?
  active            Boolean     @default(true)
  createdAt         DateTime    @default(now())

  rfpSources RfpSource[]

  @@index([active])
  @@index([agencyKind, agencyTier])
  @@index([scraperKind])
  @@index([lastVerifiedOk, scraperKind])
}

model RfpListing {
  id                 String           @id @default(cuid())
  tenantId           String
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceId           String?
  source             RfpSource?       @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  title              String
  agency             String
  agencyKind         AgencyKind?
  agencyTier         AgencyTier?
  solicitationNo     String?
  url                String?
  summary            String?
  estimatedValue     Float?
  dueAt              DateTime?
  postedAt           DateTime?
  setAside           String?
  naicsCode          String?
  placeOfPerformance String?
  matched            Boolean          @default(false)
  status             RfpListingStatus @default(NEW)
  // Match score 0-100 against the tenant's bid profile. NULL means
  // "not yet scored." scoreExplanation is a JSON string with the
  // signal breakdown so the UI can render "matched on NAICS, missed
  // on geo" tooltips and the operator can audit the ranking.
  score              Int?
  scoreExplanation   String?
  // Auto-draft attempt status (added 2026-05-01). When the sweep
  // auto-fires autopilotListing on a hot listing, we record the
  // outcome here so the UI can show "auto-drafted on date X" without
  // walking AuditEvent rows.
  autoDrafted        Boolean          @default(false)
  autoDraftedAt      DateTime?
  autoDraftError     String?
  opportunityId      String?
  opportunity        Opportunity?     @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  ownerName          String?
  discoveredAt       DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  bidDrafts BidDraft[]

  // Prevent double-ingest from concurrent sweeps. SQLite treats NULL
  // values as distinct in unique indexes (per SQL standard), so
  // listings without a solicitationNo can still co-exist — but
  // real-numbered listings can't be duplicated for the same tenant +
  // agency. Pairs with the upsert in src/lib/rfp-crawl.ts.
  @@unique([tenantId, agency, solicitationNo], name: "tenant_agency_sol_unique")
  @@index([tenantId])
  @@index([sourceId])
  @@index([tenantId, score])
  @@index([tenantId, dueAt])
  @@index([tenantId, status])
}

/// Per-tenant matching profile — what makes a listing a "good fit" for
/// THIS tenant. Used by the scoring engine to assign 0-100 scores at
/// sweep time. Each field is JSON-encoded to keep the schema stable as
/// the matching logic evolves.
///
/// Pass-11 (2026-05-01): added to support auto-tracking and auto-draft
/// across federal / state / county / municipal pipelines.
model TenantBidProfile {
  id                     String   @id @default(cuid())
  tenantId               String   @unique
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Comma-separated NAICS codes the tenant pursues. Listings whose
  // naicsCode matches any of these score full points on NAICS.
  targetNaicsJson        String   @default("[]")
  // Set-aside codes the tenant qualifies for (SDVOSB, EIGHT_A, WOSB,
  // HUBZONE, SMALL_BUSINESS, NONE). Listings whose setAside is in this
  // list score full points; UNKNOWN listings (no setAside) score
  // partial.
  qualifiedSetAsidesJson String   @default("[]")
  // Geographic preference. Listings within targetStates or
  // targetCities score full geo points; further away gets partial.
  targetStatesJson       String   @default("[]")
  targetCitiesJson       String   @default("[]")
  // Dollar value range — listings outside the range take a hit.
  minValue               Float?
  maxValue               Float?
  // Keywords / phrases boosting score when found in title/summary.
  boostKeywordsJson      String   @default("[]")
  // Keywords that should subtract from score (e.g. "demolition only"
  // for a tenant that doesn't do demo work).
  blockKeywordsJson      String   @default("[]")
  // Per-agency-tier preference — array of AgencyTier values. Empty
  // array means no preference.
  preferredTiersJson     String   @default("[]")
  // The score floor at which a listing becomes "hot" — surfaced in
  // dashboards, gets a notification, and (if the source allows)
  // qualifies for auto-draft.
  hotThreshold           Int      @default(70)
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([tenantId])
}

model BidDraft {
  id                 String         @id @default(cuid())
  tenantId           String
  tenant             Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  rfpListingId       String?
  rfpListing         RfpListing?    @relation(fields: [rfpListingId], references: [id], onDelete: SetNull)
  opportunityId      String?
  opportunity        Opportunity?   @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  title              String
  status             BidDraftStatus @default(DRAFT)
  totalValue         Float          @default(0)
  overheadPct        Float          @default(10)
  profitPct          Float          @default(8)
  winThemes          String?
  keyDifferentiators String?
  modelUsed          String         @default("stub-v1")
  authorName         String?
  submittedAt        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  sections       BidDraftSection[]
  complianceRuns ComplianceCheck[]
  lineItems      BidDraftLineItem[]

  @@index([tenantId, status])
}

model BidDraftLineItem {
  id            String   @id @default(cuid())
  draftId       String
  draft         BidDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  position      Int
  costCode      String?
  description   String
  category      String   @default("LABOR")
  quantity      Float    @default(1)
  unit          String?
  unitCost      Float    @default(0)
  laborCost     Float    @default(0)
  materialCost  Float    @default(0)
  equipmentCost Float    @default(0)
  subCost       Float    @default(0)
  markupPct     Float    @default(0)
  amount        Float    @default(0)
  createdAt     DateTime @default(now())

  @@index([draftId])
}

model RevenueProjection {
  id              String   @id @default(cuid())
  projectId       String
  project         Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  periodStart     DateTime
  periodEnd       DateTime
  forecastRevenue Float    @default(0)
  forecastCost    Float    @default(0)
  forecastMargin  Float    @default(0)
  confidence      Int      @default(50)
  source          String   @default("schedule-derived")
  createdAt       DateTime @default(now())

  @@unique([projectId, periodStart])
  @@index([projectId])
}

model AlertRule {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  category    String
  triggerType String
  configJson  String   @default("{}")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  events AlertEvent[]

  @@index([tenantId])
}

model AlertEvent {
  id             String     @id @default(cuid())
  tenantId       String
  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  ruleId         String?
  rule           AlertRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  severity       String     @default("INFO")
  title          String
  body           String?
  entityType     String?
  entityId       String?
  link           String?
  projectId      String?
  project        Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  acknowledgedAt DateTime?
  acknowledgedBy String?
  createdAt      DateTime   @default(now())

  @@index([tenantId, severity])
  @@index([projectId])
}

model BidDraftSection {
  id        String   @id @default(cuid())
  draftId   String
  draft     BidDraft @relation(fields: [draftId], references: [id], onDelete: Cascade)
  position  Int
  heading   String
  body      String
  wordCount Int      @default(0)
  status    String   @default("DRAFT")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([draftId])
}

model ComplianceCheck {
  id      String            @id @default(cuid())
  draftId String
  draft   BidDraft          @relation(fields: [draftId], references: [id], onDelete: Cascade)
  runAt   DateTime          @default(now())
  overall ComplianceOutcome @default(PENDING)
  summary String?

  items ComplianceItem[]

  @@index([draftId])
}

model ComplianceItem {
  id          String            @id @default(cuid())
  runId       String
  run         ComplianceCheck   @relation(fields: [runId], references: [id], onDelete: Cascade)
  category    String
  requirement String
  outcome     ComplianceOutcome @default(PENDING)
  evidence    String?
  source      String?

  @@index([runId])
}

// Xero / financial analytics / project P&L

/**
 * Accounting period close. Once a period is closed, all financial
 * mutations dated on or before the close date are locked. Reopen
 * requires super-admin + audit event. Drives the WIP / financial-
 * statement reporting cycle.
 */
model AccountingPeriod {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periodLabel  String // "2026-04", "Q1 2026", "FY2026"
  startDate    DateTime
  endDate      DateTime
  status       String    @default("OPEN") // OPEN | CLOSING | CLOSED | REOPENED
  closedAt     DateTime?
  closedBy     String?
  reopenedAt   DateTime?
  reopenedBy   String?
  reopenReason String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  adjustingEntries AdjustingEntry[]

  @@unique([tenantId, periodLabel])
  @@index([tenantId, status])
}

/**
 * Period-end adjusting / accrual entries. Created during close to
 * recognize revenue not yet billed, accrue costs not yet invoiced,
 * post depreciation, etc. Each entry has paired debit/credit lines.
 */
model AdjustingEntry {
  id            String           @id @default(cuid())
  periodId      String
  period        AccountingPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
  entryNumber   String
  description   String
  postedAt      DateTime         @default(now())
  postedBy      String?
  reversingDate DateTime? // for accrual reversal in the next period
  notes         String?
  linesJson     String           @default("[]") // [{accountCode, debit, credit, costCode}]
  createdAt     DateTime         @default(now())

  @@unique([periodId, entryNumber])
  @@index([periodId])
}

/**
 * Balance sheet snapshot — assets / liabilities / equity at a point
 * in time. Calculated from GL balances at period close. Stored to
 * give CFOs trended views without recomputing.
 */
model BalanceSheetSnapshot {
  id                  String   @id @default(cuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  asOf                DateTime
  // Assets
  cash                Float    @default(0)
  accountsReceivable  Float    @default(0)
  retainageReceivable Float    @default(0)
  costsInExcess       Float    @default(0)
  inventory           Float    @default(0)
  fixedAssetsNet      Float    @default(0)
  otherAssets         Float    @default(0)
  totalAssets         Float    @default(0)
  // Liabilities
  accountsPayable     Float    @default(0)
  retainagePayable    Float    @default(0)
  billingsInExcess    Float    @default(0)
  accruedExpenses     Float    @default(0)
  longTermDebt        Float    @default(0)
  otherLiabilities    Float    @default(0)
  totalLiabilities    Float    @default(0)
  // Equity
  paidInCapital       Float    @default(0)
  retainedEarnings    Float    @default(0)
  currentEarnings     Float    @default(0)
  totalEquity         Float    @default(0)
  source              String   @default("manual")
  createdAt           DateTime @default(now())

  @@unique([tenantId, asOf])
  @@index([tenantId])
}

/**
 * Rolling 13-week cash-flow forecast row. One row per (week, project,
 * category). Categories: revenue (pay-app inflow), AP (vendor
 * outflow), labor (payroll outflow), retainage release. The forecast
 * worker recalculates these from open pay apps + scheduled POs +
 * payroll runs.
 */
model CashFlowForecast {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  weekStarting DateTime
  category     String // "INFLOW_BILLING" | "OUTFLOW_AP" | "OUTFLOW_LABOR" | "INFLOW_RETAINAGE_RELEASE"
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  amount       Float
  confidence   Float    @default(1.0) // 0-1
  scenario     String   @default("base") // "base" | "best" | "worst"
  notes        String?
  source       String   @default("calc") // "calc" | "manual" | "ai"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, weekStarting])
  @@index([projectId])
}

/**
 * Cash flow + WIP statement runs — periodic statement of cash flows
 * generated from journal entries. Stored so CFOs can trend.
 */
model CashFlowStatement {
  id                  String   @id @default(cuid())
  tenantId            String
  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  periodLabel         String
  periodStart         DateTime
  periodEnd           DateTime
  operatingActivities Float    @default(0)
  investingActivities Float    @default(0)
  financingActivities Float    @default(0)
  netChange           Float    @default(0)
  beginningCash       Float    @default(0)
  endingCash          Float    @default(0)
  source              String   @default("calc")
  createdAt           DateTime @default(now())

  @@unique([tenantId, periodLabel])
  @@index([tenantId])
}

