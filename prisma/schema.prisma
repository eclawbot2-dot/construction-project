  cogs          Float    @default(0)
  grossProfit   Float    @default(0)
  opex          Float    @default(0)
  ebitda        Float    @default(0)
  netIncome     Float    @default(0)
  source        String   @default("manual")
  sourceRef     String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, statementType, periodStart, periodEnd])
  @@index([tenantId])
}

model JournalEntryRow {
  id                   String                   @id @default(cuid())
  tenantId             String
  tenant               Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entryDate            DateTime
  xeroId               String?                  @unique
  qboId                String?                  @unique
  externalSource       String?
  reference            String?
  memo                 String
  accountCode          String
  accountName          String
  entryType            JournalEntryType         @default(OPERATING_EXPENSE)
  amount               Float
  vendorName           String?
  projectId            String?
  project              Project?                 @relation(fields: [projectId], references: [id], onDelete: SetNull)
  costCode             String?
  allocationConfidence Int?
  reconciliationStatus CostReconciliationStatus @default(UNREVIEWED)
  reconciledBy         String?
  reconciledAt         DateTime?
  source               String                   @default("xero-sync")
  emailMessageId       String?
  attachmentUrl        String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  @@index([tenantId])
  @@index([projectId])
}

model ProjectPnlSnapshot {
  id                  String    @id @default(cuid())
  projectId           String    @unique
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asOf                DateTime  @default(now())
  contractValue       Float     @default(0)
  approvedCOValue     Float     @default(0)
  totalContractValue  Float     @default(0)
  billedToDate        Float     @default(0)
  costsToDate         Float     @default(0)
  committedCost       Float     @default(0)
  forecastFinalCost   Float     @default(0)
  forecastGrossMargin Float     @default(0)
  percentComplete     Float     @default(0)
  wipOverUnder        Float     @default(0)
  cashOnHand          Float     @default(0)
  lastReconciledAt    DateTime?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([projectId])
}

model InvoiceInboxConnection {
  id              String    @id @default(cuid())
  tenantId        String    @unique
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  provider        String    @default("google-workspace")
  mailbox         String
  labelFilter     String    @default("Invoices")
  senderAllowlist String    @default("[]")
  status          String    @default("DISCONNECTED")
  accessToken     String?
  refreshToken    String?
  expiresAt       DateTime?
  lastPolledAt    DateTime?
  lastPollStatus  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model InvoiceInboxMessage {
  id                String   @id @default(cuid())
  tenantId          String
  tenant            Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  externalMessageId String   @unique
  subject           String
  fromAddress       String
  receivedAt        DateTime
  vendorGuess       String?
  amountGuess       Float?
  projectGuessId    String?
  projectGuess      Project? @relation(fields: [projectGuessId], references: [id], onDelete: SetNull)
  costCodeGuess     String?
  confidence        Int      @default(0)
  status            String   @default("UNMATCHED")
  attachmentUrl     String?
  journalRowId      String?
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([tenantId])
  @@index([projectGuessId])
}

model HistoricalImport {
  id               String                 @id @default(cuid())
  tenantId         String
  tenant           Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId        String?
  project          Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  kind             HistoricalImportKind
  label            String
  filename         String
  fileSize         Int                    @default(0)
  uploadedBy       String?
  status           HistoricalImportStatus @default(UPLOADED)
  aiModel          String                 @default("bcon-reviewer-v1")
  aiSummary        String?
  aiFlagsJson      String                 @default("[]")
  rowsDetected     Int                    @default(0)
  rowsImported     Int                    @default(0)
  totalDollarValue Float                  @default(0)
  columnsJson      String                 @default("[]")
  headerRowJson    String                 @default("[]")
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt

  rows HistoricalImportRow[]

  @@index([tenantId])
  @@index([projectId])
}

model HistoricalImportRow {
  id            String           @id @default(cuid())
  importId      String
  import        HistoricalImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  rowIndex      Int
  dataJson      String
  extractedJson String           @default("{}")
  confidence    Int              @default(50)
  issuesJson    String           @default("[]")
  accepted      Boolean          @default(false)
  createdAt     DateTime         @default(now())

  @@index([importId])
}

model AiRunLog {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind         String
  inputHash    String
  entityType   String?
  entityId     String?
  outputJson   String
  confidence   Int?
  source       String   @default("heuristic")
  userFeedback String?
  feedbackNote String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([tenantId, kind, inputHash])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
}

model RecordComment {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  entityType String
  entityId   String
  authorId   String?
  authorName String
  kind       String   @default("COMMENT")
  body       String
  createdAt  DateTime @default(now())

  @@index([tenantId, entityType, entityId, createdAt])
  @@index([tenantId, createdAt])
}

enum DrawingDiscipline {
  ARCHITECTURAL
  STRUCTURAL
  MEP
  CIVIL
  LANDSCAPE
  ELECTRICAL
  PLUMBING
  MECHANICAL
  FIRE_PROTECTION
  OTHER
}

/// Drawing register entry — a versioned set of sheets for one project +
/// discipline. Captures the full Sheet/Spec lineage that req §7.7 asks
/// for: discipline classification, revision history, link to the source
/// Document, and a list of DrawingSheet rows for the sheet register.
model Drawing {
  id             String            @id @default(cuid())
  projectId      String
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  setName        String
  discipline     DrawingDiscipline @default(OTHER)
  revisionNumber Int               @default(0)
  issuedDate     DateTime?
  receivedDate   DateTime          @default(now())
  archived       Boolean           @default(false)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  sheets DrawingSheet[]

  @@index([projectId])
  @@index([projectId, discipline])
}

/// One sheet in a drawing set — e.g. "A0.1 Cover Sheet". `isCurrent`
/// flips to false when superseded by a later revision; we keep the row
/// instead of deleting so cross-references from RFIs / Submittals stay
/// stable.
model DrawingSheet {
  id          String   @id @default(cuid())
  drawingId   String
  drawing     Drawing  @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  sheetNumber String
  title       String
  fileUrl     String?
  pageNumber  Int?
  isCurrent   Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@unique([drawingId, sheetNumber])
  @@index([drawingId])
}

/// CSI MasterFormat specification section. csiDivision is the 2-digit
/// division code ("03" = Concrete, "09" = Finishes); sectionCode is the
/// full 6-digit code ("03 30 00"). Specs are project-scoped because two
/// projects can share a division but have different section content.
model SpecSection {
  id             String   @id @default(cuid())
  projectId      String
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  csiDivision    String
  sectionCode    String
  title          String
  fileUrl        String?
  revisionNumber Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([projectId, sectionCode])
  @@index([projectId])
  @@index([projectId, csiDivision])
}

enum CandidateStatus {
  NEW
  SCREENING
  INTERVIEWING
  OFFER
  HIRED
  REJECTED
  WITHDRAWN
  ARCHIVED
}

enum JobReqStatus {
  DRAFT
  OPEN
  ON_HOLD
  FILLED
  CANCELLED
  CLOSED
}

enum SubmissionStage {
  SUBMITTED
  RECRUITER_SCREEN
  TECH_SCREEN
  CLIENT_INTERVIEW
  REFERENCE_CHECK
  OFFER_EXTENDED
  OFFER_ACCEPTED
  OFFER_DECLINED
  PLACED
  REJECTED
  WITHDRAWN
}

enum PlacementStatus {
  PENDING_START
  ACTIVE
  EXTENDED
  ENDING_SOON
  ENDED
  TERMINATED
  CONVERTED
}

/// ATS candidate. Tenant-scoped because recruiters work within a single
/// company/agency tenant; cross-tenant candidate sharing is not in scope
/// per req §7.1A. Resume URL points at the storage adapter (PR #15).
model Candidate {
  id              String          @id @default(cuid())
  tenantId        String
  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firstName       String
  lastName        String
  email           String?
  phone           String?
  city            String?
  state           String?
  country         String?         @default("US")
  status          CandidateStatus @default(NEW)
  laborCategory   String?
  primarySkill    String?
  skillsJson      String          @default("[]")
  resumeUrl       String?
  linkedInUrl     String?
  rateExpectation Float?
  source          String?
  ownerUserId     String?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  submissions Submission[]
  placements  Placement[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, laborCategory])
}

/// Open job requisition under a tenant. Optional projectId binds the req
/// to a construction project (e.g. a self-perform crew slot); reqs that
/// don't tie to a project (corporate roles, recruiter pools) leave it null.
model JobRequisition {
  id              String       @id @default(cuid())
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  reqNumber       String
  title           String
  hiringManager   String?
  laborCategory   String?
  location        String?
  remoteAllowed   Boolean      @default(false)
  rateMin         Float?
  rateMax         Float?
  status          JobReqStatus @default(DRAFT)
  openings        Int          @default(1)
  filledCount     Int          @default(0)
  description     String?
  postedDate      DateTime?
  targetStartDate DateTime?
  closedAt        DateTime?
  closedReason    String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  submissions Submission[]

  @@unique([tenantId, reqNumber])
  @@index([tenantId, status])
  @@index([projectId])
}

/// Candidate × JobRequisition pipeline state. One row per submission
/// attempt — a candidate withdrawn and re-submitted gets a new row so
/// the activity history stays append-only.
model Submission {
  id            String          @id @default(cuid())
  tenantId      String
  candidateId   String
  candidate     Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  reqId         String
  req           JobRequisition  @relation(fields: [reqId], references: [id], onDelete: Cascade)
  stage         SubmissionStage @default(SUBMITTED)
  recruiterName String?
  rateOffered   Float?
  notes         String?
  submittedAt   DateTime        @default(now())
  decidedAt     DateTime?
  rejectReason  String?

  placement Placement?

  @@unique([candidateId, reqId])
  @@index([tenantId])
  @@index([reqId, stage])
  @@index([candidateId])
}

/// Active or completed placement of a candidate against a project /
/// contract. Captures bill/pay rate split and the lifecycle dates that
/// drive renewal alerts (req §7.1A placements). One submission can
/// produce at most one placement; subsequent re-engagements create new
/// placements pointing at fresh submissions.
model Placement {
  id              String          @id @default(cuid())
  tenantId        String
  candidateId     String
  candidate       Candidate       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  submissionId    String?         @unique
  submission      Submission?     @relation(fields: [submissionId], references: [id], onDelete: SetNull)
  projectId       String?
  contractRef     String?
  laborCategory   String?
  department      String?
  startDate       DateTime
  endDate         DateTime?
  billRate        Float?
  payRate         Float?
  status          PlacementStatus @default(PENDING_START)
  performanceNote String?
  redeployable    Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([projectId])
  @@index([candidateId])
}
