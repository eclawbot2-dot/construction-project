generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

// Local dev runs on SQLite via better-sqlite3 for friction-free setup.
// For production, change `provider` to "postgresql", set DATABASE_URL to a
// Postgres URL, install `@prisma/adapter-pg` and `pg`, and update
// src/lib/prisma.ts to instantiate PrismaPg instead of PrismaBetterSqlite3.
//
// Currency-bearing fields throughout this schema currently use `Float`,
// which on Postgres maps to DOUBLE PRECISION (IEEE-754) and accumulates
// rounding errors when summed across line items. Production migration
// must convert these to `Decimal @db.Decimal(15, 2)`. See
// docs/pass-audit-07.md §1.2 for the full list and migration plan.
datasource db {
  provider = "sqlite"
}

enum ProjectMode {
  SIMPLE
  VERTICAL
  HEAVY_CIVIL
}

enum UserRoleTemplate {
  ADMIN
  EXECUTIVE
  MANAGER
  RECRUITER
  COORDINATOR
  CAPTURE_MANAGER
  PROGRAM_MANAGER
  ACCOUNT_EXECUTIVE
  VIEWER
  PROJECT_ENGINEER
  SUPERINTENDENT
  FOREMAN
  CONTROLLER
  SAFETY_MANAGER
  QUALITY_MANAGER
}

enum ProjectStage {
  PRECONSTRUCTION
  ACTIVE
  CLOSEOUT
  WARRANTY
}

enum ThreadChannel {
  GENERAL
  SCHEDULE
  BUDGET
  OWNER
  FIELD
  SAFETY
  PROCUREMENT
  CLOSEOUT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  COMPLETE
}

enum WorkflowStatus {
  DRAFT
  UNDER_REVIEW
  APPROVED
  REJECTED
  CLOSED
}

enum DocumentClass {
  CONTRACT
  DRAWING
  SPEC
  PERMIT
  RFI
  SUBMITTAL
  MEETING_MINUTES
  DAILY_REPORT
  PHOTO
  SAFETY
  QUALITY
  INVOICE
  CHANGE
  CLOSEOUT
  WARRANTY
  TEST_REPORT
  TICKET
  OTHER
}

enum BudgetLineType {
  COST_CODE
  PAY_ITEM
  ALLOWANCE
  CONTINGENCY
}

enum ChangeOrderKind {
  PCO
  COR
  OCO
  INTERNAL
}

enum ChangeOrderStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
  EXECUTED
  VOID
}

enum ScheduleDependencyType {
  FS
  SS
  FF
  SF
}

enum ContractType {
  PRIME_OWNER
  SUBCONTRACT
  PURCHASE_ORDER
  MSA
  TASK_ORDER
  GC_CONTRACT
  FEE_AGREEMENT
}

enum ContractStatus {
  DRAFT
  NEGOTIATING
  EXECUTED
  ACTIVE
  COMPLETED
  TERMINATED
}

enum PayApplicationStatus {
  DRAFT
  SUBMITTED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PAID
}

enum LienWaiverType {
  CONDITIONAL_PARTIAL
  UNCONDITIONAL_PARTIAL
  CONDITIONAL_FINAL
  UNCONDITIONAL_FINAL
}

enum LienWaiverStatus {
  PENDING
  RECEIVED
  REJECTED
  EXPIRED
}

enum InspectionKind {
  MUNICIPAL
  THIRD_PARTY
  INTERNAL_QC
  PRE_POUR
  PRE_COVER
  FINAL
  OSHA
  ENVIRONMENTAL
}

enum InspectionResult {
  PENDING
  PASS
  FAIL
  CONDITIONAL
  WAIVED
}

enum OpportunityStage {
  LEAD
  QUALIFIED
  PROPOSAL
  BID
  AWARDED
  LOST
  WITHDRAWN
}

enum BidPackageStatus {
  PLANNING
  INVITED
  COLLECTING
  LEVELING
  AWARDED
  CANCELLED
}

enum SubBidStatus {
  INVITED
  DECLINED
  BIDDING
  SUBMITTED
  SELECTED
  NOT_SELECTED
}

enum PrequalificationStatus {
  NOT_STARTED
  IN_REVIEW
  APPROVED
  DECLINED
  EXPIRED
}

enum InsuranceType {
  GENERAL_LIABILITY
  WORKERS_COMP
  AUTO
  UMBRELLA
  PROFESSIONAL
  POLLUTION
}

enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum SubInvoiceStatus {
  RECEIVED
  UNDER_REVIEW
  APPROVED
  PAID
  DISPUTED
  REJECTED
}

enum WarrantyStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REJECTED
  ESCALATED
}

enum PermitStatus {
  PLANNED
  APPLIED
  UNDER_REVIEW
  ISSUED
  EXPIRED
  FINALED
  REJECTED
}

enum InspectionLookupStatus {
  NEVER
  FETCHED
  STALE
  ERROR
}

enum InspectionItemStatus {
  PENDING
  PASS
  FAIL
  NA
}

enum RfpSourceStatus {
  ACTIVE
  PAUSED
  ERROR
}

enum RfpListingStatus {
  NEW
  TRIAGED
  QUALIFIED
  PURSUING
  SUBMITTED
  WON
  LOST
  DECLINED
}

enum BidDraftStatus {
  DRAFT
  UNDER_REVIEW
  FINAL
  SUBMITTED
}

enum ComplianceOutcome {
  PENDING
  PASS
  FAIL
  WAIVED
  NOT_APPLICABLE
}

enum XeroConnectionStatus {
  DISCONNECTED
  CONNECTED
  EXPIRED
  ERROR
}

enum QboConnectionStatus {
  DISCONNECTED
  CONNECTED
  EXPIRED
  ERROR
}

enum JournalEntryType {
  REVENUE
  COST_OF_GOODS
  OPERATING_EXPENSE
  INDIRECT_COST
  OTHER_INCOME
  OTHER_EXPENSE
}

enum CostReconciliationStatus {
  UNREVIEWED
  SUGGESTED
  CONFIRMED
  NEEDS_INPUT
  REJECTED
}

enum HistoricalImportKind {
  PROJECT_ACTUALS
  BID_HISTORY
  INCOME_STATEMENT
  BUDGET_TEMPLATE
  SCHEDULE_OF_VALUES
  VENDOR_LIST
}

enum HistoricalImportStatus {
  UPLOADED
  PARSED
  AI_REVIEWED
  IMPORTED
  REJECTED
}

enum DailyLogType {
  GENERAL
  AREA
  CREW
}

model Tenant {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  primaryMode   ProjectMode
  enabledModes  String      @default("[]")
  featurePacks  String      @default("[]")
  terminology   String      @default("{}")
  brandingTheme String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  businessUnits        BusinessUnit[]
  memberships          Membership[]
  projects             Project[]
  companies            Company[]
  contacts             Contact[]
  auditEvents          AuditEvent[]
  workflowTemplates    WorkflowTemplate[]
  notificationRules    NotificationRule[]
  historicalEstimates  HistoricalEstimate[]
  opportunities        Opportunity[]
  vendors              Vendor[]
  rfpSources           RfpSource[]
  rfpListings          RfpListing[]
  bidDrafts            BidDraft[]
  xeroConnection       XeroConnection?
  qboConnection        QboConnection?
  chartOfAccounts      ChartOfAccount[]
  financialStatements  FinancialStatement[]
  journalEntries       JournalEntryRow[]
  invoiceInbox         InvoiceInboxConnection?
  invoiceInboxMessages InvoiceInboxMessage[]
  alertRules           AlertRule[]
  alertEvents          AlertEvent[]
  historicalImports    HistoricalImport[]
  aiRuns               AiRunLog[]
  recordComments       RecordComment[]
  candidates           Candidate[]
  jobRequisitions      JobRequisition[]
}

model BusinessUnit {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        String
  defaultMode ProjectMode
  region      String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  memberships Membership[]
  projects    Project[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model User {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String
  active      Boolean   @default(true)
  superAdmin  Boolean   @default(false)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  memberships Membership[]
  messages    ThreadMessage[]
  tasks       Task[]          @relation("TaskAssignee")
  approvals   Approval[]      @relation("ApprovalApprover")
  auditEvents AuditEvent[]    @relation("AuditActor")
  watchers    Watcher[]
}

model Membership {
  id              String           @id @default(cuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessUnitId  String?
  businessUnit    BusinessUnit?    @relation(fields: [businessUnitId], references: [id])
  roleTemplate    UserRoleTemplate
  permissionsJson String           @default("{}")
  createdAt       DateTime         @default(now())

  @@unique([tenantId, userId])
}

model Company {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  companyType String
  market      String?
  region      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts Contact[]

  @@index([tenantId])
}

model Contact {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  name      String
  email     String?
  phone     String?
  roleTitle String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([companyId])
}

model Project {
  id                String        @id @default(cuid())
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessUnitId    String?
  businessUnit      BusinessUnit? @relation(fields: [businessUnitId], references: [id])
  name              String
  code              String
  mode              ProjectMode
  stage             ProjectStage  @default(PRECONSTRUCTION)
  address           String?
  ownerName         String?
  contractType      String?
  contractValue     Float?
  marginTargetPct   Float?
  progressPct       Float         @default(0)
  healthScore       Int           @default(75)
  startDate         DateTime?
  endDate           DateTime?
  configurationJson String        @default("{}")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  threads              Thread[]
  tasks                Task[]
  documents            Document[]
  rfis                 RFI[]
  submittals           Submittal[]
  dailyLogs            DailyLog[]
  budgets              Budget[]
  quantities           QuantityBudget[]
  productionEntries    ProductionEntry[]
  tickets              Ticket[]
  safetyIncidents      SafetyIncident[]
  punchItems           PunchItem[]
  meetings             Meeting[]
  workflowRuns         WorkflowRun[]
  watchers             Watcher[]
  approvalRoutes       ApprovalRoute[]
  equipmentRecords     EquipmentRecord[]
  materialRecords      MaterialRecord[]
  changeOrders         ChangeOrder[]
  scheduleTasks        ScheduleTask[]
  contracts            Contract[]
  payApplications      PayApplication[]
  lienWaivers          LienWaiver[]
  inspections          Inspection[]
  opportunities        Opportunity[]
  bidPackages          BidPackage[]
  timeEntries          TimeEntry[]
  subInvoices          SubInvoice[]
  warrantyItems        WarrantyItem[]
  purchaseOrders       PurchaseOrder[]
  permits              Permit[]
  journalEntries       JournalEntryRow[]
  pnlSnapshot          ProjectPnlSnapshot?
  invoiceInboxMessages InvoiceInboxMessage[]
  revenueProjections   RevenueProjection[]
  alertEvents          AlertEvent[]
  historicalImports    HistoricalImport[]
  drawings             Drawing[]
  specSections         SpecSection[]
  jobRequisitions      JobRequisition[]

  @@unique([tenantId, code])
}

model Thread {
  id        String        @id @default(cuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  channel   ThreadChannel
  isDefault Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  messages ThreadMessage[]

  @@index([projectId])
}

model ThreadMessage {
  id           String   @id @default(cuid())
  threadId     String
  thread       Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId     String
  author       User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body         String
  decisionFlag Boolean  @default(false)
  pinned       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([threadId])
  @@index([authorId])
  @@index([createdAt])
}

model Task {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    String     @default("Medium")
  dueDate     DateTime?
  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  sourceType  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId])
  @@index([assigneeId])
}

model WorkflowTemplate {
  id         String       @id @default(cuid())
  tenantId   String
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  mode       ProjectMode?
  module     String
  configJson String       @default("{}")
  createdAt  DateTime     @default(now())

  @@index([tenantId])
}

model WorkflowRun {
  id           String         @id @default(cuid())
  projectId    String
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateName String
  module       String
  status       WorkflowStatus @default(DRAFT)
  payloadJson  String         @default("{}")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  watchers Watcher[]

  @@index([projectId])
}

model Watcher {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workflowRunId String?
  workflowRun   WorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  userId        String?
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel       String
  objectType    String
  objectId      String?
  required      Boolean      @default(false)
  createdAt     DateTime     @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([workflowRunId])
}

model NotificationRule {
  id           String            @id @default(cuid())
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  roleTemplate UserRoleTemplate?
  triggerType  String
  delivery     String
  cadence      String?
  slaHours     Int?
  configJson   String            @default("{}")
  createdAt    DateTime          @default(now())

  @@index([tenantId])
}

model ApprovalRoute {
  id           String            @id @default(cuid())
  projectId    String
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  targetType   String
  targetId     String?
  name         String
  status       WorkflowStatus    @default(DRAFT)
  approverRole UserRoleTemplate?
  stepsJson    String            @default("[]")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([projectId])
}

model EquipmentRecord {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  equipmentCode    String
  description      String
  ownershipType    String
  assignedCrew     String?
  utilizationHours Float?   @default(0)
  status           String   @default("Active")
  createdAt        DateTime @default(now())

  @@index([projectId])
}

model MaterialRecord {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  materialType String
  quantity     Float
  unit         String
  status       String   @default("Received")
  source       String?
  locationTag  String?
  createdAt    DateTime @default(now())

  @@index([projectId])
}

model HistoricalEstimate {
  id             String      @id @default(cuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mode           ProjectMode
  title          String
  projectType    String?
  geography      String?
  lineItemCode   String?
  unitCost       Float?
  productionRate Float?
  confidencePct  Int?
  metadataJson   String      @default("{}")
  createdAt      DateTime    @default(now())

  @@index([tenantId])
}

model Document {
  id            String        @id @default(cuid())
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String
  documentClass DocumentClass
  folderPath    String?
  versionLabel  String        @default("v1")
  metadataJson  String        @default("{}")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([projectId])
}

model RFI {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number          String
  subject         String
  question        String?
  response        String?
  status          WorkflowStatus @default(DRAFT)
  dueDate         DateTime?
  ballInCourt     String?
  submittedAt     DateTime?
  submittedBy     String?
  respondedAt     DateTime?
  respondedBy     String?
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?
  approvalNote    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([projectId, number])
  @@index([projectId])
}

model Submittal {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number          String
  title           String
  specSection     String?
  status          WorkflowStatus @default(DRAFT)
  longLead        Boolean        @default(false)
  submittedAt     DateTime?
  submittedBy     String?
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?
  approvalNote    String?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([projectId, number])
  @@index([projectId])
}

model Meeting {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  meetingType String
  scheduledAt DateTime
  notes       String?
  createdAt   DateTime @default(now())

  @@index([projectId])
}

model DailyLog {
  id        String       @id @default(cuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  logDate   DateTime
  logType   DailyLogType @default(GENERAL)
  weather   String?
  summary   String
  manpower  Int          @default(0)
  notes     String?
  createdAt DateTime     @default(now())

  productionEntries ProductionEntry[]

  @@index([projectId, createdAt])
}

model Budget {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  originalValue Float
  currentValue  Float
  forecastFinal Float?
  createdAt     DateTime @default(now())

  lines BudgetLine[]

  @@index([projectId])
}

model BudgetLine {
  id            String         @id @default(cuid())
  budgetId      String
  budget        Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  code          String
  description   String
  lineType      BudgetLineType
  budgetAmount  Float
  committedCost Float          @default(0)
  actualCost    Float          @default(0)
  createdAt     DateTime       @default(now())

  @@index([budgetId])
}

model QuantityBudget {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code         String
  description  String
  unit         String
  budgetQty    Float
  installedQty Float    @default(0)
  earnedQty    Float    @default(0)
  locationTag  String?
  createdAt    DateTime @default(now())

  @@index([projectId])
}

model ProductionEntry {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dailyLogId     String?
  dailyLog       DailyLog? @relation(fields: [dailyLogId], references: [id], onDelete: SetNull)
  activity       String
  crewName       String?
  installedQty   Float     @default(0)
  unit           String?
  productionRate Float?
  equipmentHours Float?
  locationTag    String?
  createdAt      DateTime  @default(now())

  @@index([projectId, createdAt])
  @@index([dailyLogId])
}

model Ticket {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ticketNumber String
  materialType String
  quantity     Float
  unit         String
  source       String?
  destination  String?
  createdAt    DateTime @default(now())

  @@unique([projectId, ticketNumber])
  @@index([projectId])
}

model SafetyIncident {
  id                String         @id @default(cuid())
  projectId         String
  project           Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title             String
  severity          String
  description       String?
  status            WorkflowStatus @default(DRAFT)
  occurredAt        DateTime
  submittedAt       DateTime?
  submittedBy       String?
  approvedAt        DateTime?
  approvedBy        String?
  rejectedAt        DateTime?
  rejectedBy        String?
  rejectionReason   String?
  approvalNote      String?
  correctiveActions String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime?      @updatedAt

  @@index([projectId])
}

model PunchItem {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  area            String?
  description     String?
  trade           String?
  assignedTo      String?
  status          WorkflowStatus @default(DRAFT)
  dueDate         DateTime?
  closedAt        DateTime?
  closedBy        String?
  submittedAt     DateTime?
  submittedBy     String?
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?
  approvalNote    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime?      @updatedAt

  @@index([projectId])
}

model Approval {
  id         String         @id @default(cuid())
  approverId String
  approver   User           @relation("ApprovalApprover", fields: [approverId], references: [id], onDelete: Cascade)
  targetType String
  targetId   String
  status     WorkflowStatus @default(DRAFT)
  createdAt  DateTime       @default(now())

  @@index([approverId])
}

model AuditEvent {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  entityType String
  entityId   String
  action     String
  beforeJson String?
  afterJson  String?
  source     String?
  createdAt  DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([actorId])
}

model ChangeOrder {
  id                 String            @id @default(cuid())
  projectId          String
  project            Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  coNumber           String
  kind               ChangeOrderKind   @default(PCO)
  title              String
  description        String?
  reason             String?
  amount             Float             @default(0)
  markupPct          Float             @default(0)
  scheduleImpactDays Int               @default(0)
  status             ChangeOrderStatus @default(DRAFT)
  requestedById      String?
  approvedById       String?
  requestedAt        DateTime?
  approvedAt         DateTime?
  submittedBy        String?
  approvedBy         String?
  rejectedAt         DateTime?
  rejectedBy         String?
