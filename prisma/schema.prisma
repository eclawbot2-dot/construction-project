enum DailyLogType {
  GENERAL
  AREA
  CREW
}

model Tenant {
  id              String      @id @default(cuid())
  name            String
  slug            String      @unique
  primaryMode     ProjectMode
  enabledModes    String      @default("[]")
  featurePacks    String      @default("[]")
  terminology     String      @default("{}")
  brandingTheme   String?
  // Backup config (PR #29). When backupEnabled is true the nightly cron
  // dumps this tenant's data graph to ./uploads/backups/<slug>/<date>.json
  // AND, if backupDirectory is set, copies the same file there. The
  // recommended setup is to point backupDirectory at a OneDrive or
  // Google Drive sync folder so the host's desktop client uploads it
  // off-machine automatically.
  backupEnabled   Boolean     @default(true)
  backupDirectory String?
  lastBackupAt    DateTime?
  lastBackupBytes Int?
  lastBackupError String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  businessUnits        BusinessUnit[]
  memberships          Membership[]
  projects             Project[]
  companies            Company[]
  contacts             Contact[]
  auditEvents          AuditEvent[]
  workflowTemplates    WorkflowTemplate[]
  notificationRules    NotificationRule[]
  historicalEstimates  HistoricalEstimate[]
  opportunities        Opportunity[]
  vendors              Vendor[]
  rfpSources           RfpSource[]
  rfpListings          RfpListing[]
  bidDrafts            BidDraft[]
  xeroConnection       XeroConnection?
  qboConnection        QboConnection?
  chartOfAccounts      ChartOfAccount[]
  financialStatements  FinancialStatement[]
  journalEntries       JournalEntryRow[]
  invoiceInbox         InvoiceInboxConnection?
  invoiceInboxMessages InvoiceInboxMessage[]
  alertRules           AlertRule[]
  alertEvents          AlertEvent[]
  historicalImports    HistoricalImport[]
  aiRuns               AiRunLog[]
  recordComments       RecordComment[]
  candidates           Candidate[]
  jobRequisitions      JobRequisition[]
  commissionRules      CommissionRule[]
  commissionAccruals   CommissionAccrual[]
  captureRecords       CaptureRecord[]
  onboardingPaths      OnboardingPath[]
  bidProfile           TenantBidProfile?
}

model BusinessUnit {
  id          String      @id @default(cuid())
  tenantId    String
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  code        String
  defaultMode ProjectMode
  region      String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  memberships Membership[]
  projects    Project[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model User {
  id          String    @id @default(cuid())
  name        String
  email       String    @unique
  password    String
  active      Boolean   @default(true)
  superAdmin  Boolean   @default(false)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  memberships Membership[]
  messages    ThreadMessage[]
  tasks       Task[]          @relation("TaskAssignee")
  approvals   Approval[]      @relation("ApprovalApprover")
  auditEvents AuditEvent[]    @relation("AuditActor")
  watchers    Watcher[]
}

model Membership {
  id              String           @id @default(cuid())
  tenantId        String
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId          String
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessUnitId  String?
  businessUnit    BusinessUnit?    @relation(fields: [businessUnitId], references: [id])
  roleTemplate    UserRoleTemplate
  permissionsJson String           @default("{}")
  createdAt       DateTime         @default(now())

  @@unique([tenantId, userId])
}

model Company {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  companyType String
  market      String?
  region      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts Contact[]

  @@index([tenantId])
}

model Contact {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  name      String
  email     String?
  phone     String?
  roleTitle String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([companyId])
}

model Project {
  id                String        @id @default(cuid())
  tenantId          String
  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessUnitId    String?
  businessUnit      BusinessUnit? @relation(fields: [businessUnitId], references: [id])
  name              String
  code              String
  mode              ProjectMode
  stage             ProjectStage  @default(PRECONSTRUCTION)
  address           String?
  ownerName         String?
  contractType      String?
  contractValue     Float?
  marginTargetPct   Float?
  progressPct       Float         @default(0)
  healthScore       Int           @default(75)
  startDate         DateTime?
  endDate           DateTime?
  configurationJson String        @default("{}")
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  threads              Thread[]
  tasks                Task[]
  documents            Document[]
  rfis                 RFI[]
  submittals           Submittal[]
  dailyLogs            DailyLog[]
  budgets              Budget[]
  quantities           QuantityBudget[]
  productionEntries    ProductionEntry[]
  tickets              Ticket[]
  safetyIncidents      SafetyIncident[]
  punchItems           PunchItem[]
  meetings             Meeting[]
  workflowRuns         WorkflowRun[]
  watchers             Watcher[]
  approvalRoutes       ApprovalRoute[]
  equipmentRecords     EquipmentRecord[]
  materialRecords      MaterialRecord[]
  changeOrders         ChangeOrder[]
  scheduleTasks        ScheduleTask[]
  contracts            Contract[]
  payApplications      PayApplication[]
  lienWaivers          LienWaiver[]
  inspections          Inspection[]
  opportunities        Opportunity[]
  bidPackages          BidPackage[]
  timeEntries          TimeEntry[]
  subInvoices          SubInvoice[]
  warrantyItems        WarrantyItem[]
  purchaseOrders       PurchaseOrder[]
  permits              Permit[]
  journalEntries       JournalEntryRow[]
  pnlSnapshot          ProjectPnlSnapshot?
  invoiceInboxMessages InvoiceInboxMessage[]
  revenueProjections   RevenueProjection[]
  alertEvents          AlertEvent[]
  historicalImports    HistoricalImport[]
  drawings             Drawing[]
  specSections         SpecSection[]
  jobRequisitions      JobRequisition[]
  crewAssignments      CrewAssignment[]
  placements           Placement[]

  @@unique([tenantId, code])
}

model Thread {
  id        String        @id @default(cuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title     String
  channel   ThreadChannel
  isDefault Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  messages ThreadMessage[]

  @@index([projectId])
}

model ThreadMessage {
  id           String   @id @default(cuid())
  threadId     String
  thread       Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId     String
  author       User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body         String
  decisionFlag Boolean  @default(false)
  pinned       Boolean  @default(false)
  createdAt    DateTime @default(now())

  @@index([threadId])
  @@index([authorId])
  @@index([createdAt])
}

model Task {
  id          String     @id @default(cuid())
  projectId   String
  project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      TaskStatus @default(TODO)
  priority    String     @default("Medium")
  dueDate     DateTime?
  assigneeId  String?
  assignee    User?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  sourceType  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([projectId])
  @@index([assigneeId])
}

model WorkflowTemplate {
  id         String       @id @default(cuid())
  tenantId   String
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name       String
  mode       ProjectMode?
  module     String
  configJson String       @default("{}")
  createdAt  DateTime     @default(now())

  @@index([tenantId])
}

model WorkflowRun {
  id           String         @id @default(cuid())
  projectId    String
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  templateName String
  module       String
  status       WorkflowStatus @default(DRAFT)
  // entityType + entityId promote the (formerly payloadJson-only)
  // identifier of the underlying entity to first-class columns. Lets
  // findActiveRunFor do an O(log N) index lookup instead of scanning the
  // most-recent 50 rows and parsing JSON. payloadJson stays for any extra
  // metadata callers want to attach.
  entityType   String?
  entityId     String?
  payloadJson  String         @default("{}")
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  watchers Watcher[]

  @@index([projectId])
  @@index([projectId, entityType, entityId, status])
}

model Watcher {
  id            String       @id @default(cuid())
  projectId     String
  project       Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workflowRunId String?
  workflowRun   WorkflowRun? @relation(fields: [workflowRunId], references: [id], onDelete: SetNull)
  userId        String?
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  channel       String
  objectType    String
  objectId      String?
  required      Boolean      @default(false)
  createdAt     DateTime     @default(now())

  @@index([projectId])
  @@index([userId])
  @@index([workflowRunId])
}

model NotificationRule {
  id           String            @id @default(cuid())
  tenantId     String
  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  roleTemplate UserRoleTemplate?
  triggerType  String
  delivery     String
  cadence      String?
  slaHours     Int?
  configJson   String            @default("{}")
  createdAt    DateTime          @default(now())

  @@index([tenantId])
}

model ApprovalRoute {
  id           String            @id @default(cuid())
  projectId    String
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  targetType   String
  targetId     String?
  name         String
  status       WorkflowStatus    @default(DRAFT)
  approverRole UserRoleTemplate?
  stepsJson    String            @default("[]")
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([projectId])
}

model EquipmentRecord {
  id               String   @id @default(cuid())
  projectId        String
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  equipmentCode    String
  description      String
  ownershipType    String
  assignedCrew     String?
  utilizationHours Float?   @default(0)
  status           String   @default("Active")
  createdAt        DateTime @default(now())

  @@index([projectId])
}

model MaterialRecord {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  materialType String
  quantity     Float
  unit         String
  status       String   @default("Received")
  source       String?
  locationTag  String?
  createdAt    DateTime @default(now())

  @@index([projectId])
}

model HistoricalEstimate {
  id             String      @id @default(cuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mode           ProjectMode
  title          String
  projectType    String?
  geography      String?
  lineItemCode   String?
  unitCost       Float?
  productionRate Float?
  confidencePct  Int?
  metadataJson   String      @default("{}")
  createdAt      DateTime    @default(now())

  @@index([tenantId])
}

model Document {
  id            String        @id @default(cuid())
  projectId     String
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title         String
  documentClass DocumentClass
  folderPath    String?
  versionLabel  String        @default("v1")
  metadataJson  String        @default("{}")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([projectId])
}

model RFI {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number          String
  subject         String
  question        String?
  response        String?
  status          WorkflowStatus @default(DRAFT)
  dueDate         DateTime?
  ballInCourt     String?
  submittedAt     DateTime?
  submittedBy     String?
  respondedAt     DateTime?
  respondedBy     String?
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?
  approvalNote    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([projectId, number])
  @@index([projectId])
}

model Submittal {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  number          String
  title           String
  specSection     String?
  status          WorkflowStatus @default(DRAFT)
  longLead        Boolean        @default(false)
  submittedAt     DateTime?
  submittedBy     String?
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?
  approvalNote    String?
  notes           String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([projectId, number])
  @@index([projectId])
}

model Meeting {
  id          String   @id @default(cuid())
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  meetingType String
  scheduledAt DateTime
  notes       String?
  createdAt   DateTime @default(now())

  @@index([projectId])
}

model DailyLog {
  id        String       @id @default(cuid())
  projectId String
  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  logDate   DateTime
  logType   DailyLogType @default(GENERAL)
  weather   String?
  summary   String
  manpower  Int          @default(0)
  notes     String?
  // Geotagging (req §7.24): heavy-civil and field workflows need
  // station/segment + lat/lon so daily logs can be plotted on a map
  // and associated with utility runs / road segments.
  segment   String?
  station   String?
  latitude  Float?
  longitude Float?
  createdAt DateTime     @default(now())

  productionEntries ProductionEntry[]
  crewAssignments   CrewAssignment[]

  @@index([projectId, createdAt])
}

model Budget {
  id            String   @id @default(cuid())
  projectId     String
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name          String
  originalValue Float
  currentValue  Float
  forecastFinal Float?
  createdAt     DateTime @default(now())

  lines BudgetLine[]

  @@index([projectId])
}

model BudgetLine {
  id            String         @id @default(cuid())
  budgetId      String
  budget        Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  code          String
  description   String
  lineType      BudgetLineType
  budgetAmount  Float
  committedCost Float          @default(0)
  actualCost    Float          @default(0)
  createdAt     DateTime       @default(now())

  @@index([budgetId])
}

model QuantityBudget {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  code         String
  description  String
  unit         String
  budgetQty    Float
  installedQty Float    @default(0)
  earnedQty    Float    @default(0)
  locationTag  String?
  createdAt    DateTime @default(now())

  @@index([projectId])
}

model ProductionEntry {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  dailyLogId     String?
  dailyLog       DailyLog? @relation(fields: [dailyLogId], references: [id], onDelete: SetNull)
  activity       String
  crewName       String?
  installedQty   Float     @default(0)
  unit           String?
  productionRate Float?
  equipmentHours Float?
  locationTag    String?
  createdAt      DateTime  @default(now())

  @@index([projectId, createdAt])
  @@index([dailyLogId])
}

model Ticket {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  ticketNumber String
  materialType String
  quantity     Float
  unit         String
  source       String?
  destination  String?
  createdAt    DateTime @default(now())

  @@unique([projectId, ticketNumber])
  @@index([projectId])
}

model SafetyIncident {
  id                String         @id @default(cuid())
  projectId         String
  project           Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title             String
  severity          String
  description       String?
  status            WorkflowStatus @default(DRAFT)
  occurredAt        DateTime
  submittedAt       DateTime?
  submittedBy       String?
  approvedAt        DateTime?
  approvedBy        String?
  rejectedAt        DateTime?
  rejectedBy        String?
  rejectionReason   String?
  approvalNote      String?
  correctiveActions String?
  // Geotagging (req §7.24): safety reporting often needs precise location
  // for OSHA filings and trend mapping by area / station / utility run.
  segment           String?
  station           String?
  latitude          Float?
  longitude         Float?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime?      @updatedAt

  @@index([projectId])
}

model PunchItem {
  id              String         @id @default(cuid())
  projectId       String
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title           String
  area            String?
  description     String?
  trade           String?
  assignedTo      String?
  status          WorkflowStatus @default(DRAFT)
  dueDate         DateTime?
  closedAt        DateTime?
  closedBy        String?
  submittedAt     DateTime?
  submittedBy     String?
  approvedAt      DateTime?
  approvedBy      String?
  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?
  approvalNote    String?
  // Geotagging (req §7.24): punch items frequently reference a specific
