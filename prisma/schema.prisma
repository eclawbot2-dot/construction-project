  autoLogin         Boolean                    @default(false)
  // Auto-draft policy. When enabled, listings whose computed score is
  // >= autoDraftMinScore at sweep time skip manual review and run
  // autopilotListing() right away. Default 70 is sensible; the UI
  // exposes per-source overrides.
  autoDraftEnabled  Boolean                    @default(false)
  autoDraftMinScore Int                        @default(70)
  lastAuthAt        DateTime?
  lastCheckedAt     DateTime?
  lastCheckNote     String?
  lastResultCount   Int                        @default(0)
  createdAt         DateTime                   @default(now())
  updatedAt         DateTime                   @updatedAt

  listings RfpListing[]

  @@index([tenantId])
  @@index([catalogId])
}

enum AgencyKind {
  FEDERAL
  STATE
  COUNTY
  MUNICIPAL
  TRIBAL
  AGGREGATOR
  PRIVATE
  AUTHORITY
}

/// How the platform pulls listings from a portal. Pass-11: replaces the
/// previous deterministic mock crawler. Each portal in the catalog
/// declares its scraperKind and the dispatcher in src/lib/scrapers/
/// index.ts routes accordingly. Portals marked MANUAL are visible in
/// the catalog so operators can find them, but the sweep refuses to
/// fabricate data — operators visit those portals' web UIs directly
/// until a real scraper ships.
enum ScraperKind {
  API
  RSS
  HTML
  MANUAL
  DEPRECATED
}

/// Agency tier — coarse grouping under FEDERAL. Lets the catalog UI
/// render "DoD branches" / "VA centers" / "GSA-wide" categories without
/// hard-coding the entire NAICS taxonomy.
enum AgencyTier {
  CIVILIAN
  DOD
  VA
  USACE
  GSA
  HOMELAND
  ENERGY
  TRANSPORTATION
  HEALTH
  EDUCATION
  INDEPENDENT
  OTHER
}

model SolicitationPortalCatalog {
  id            String      @id @default(cuid())
  name          String
  url           String      @unique
  category      String
  // Structured agency classification (added 2026-05-01) lets the
  // discover UI categorize portals federal vs state vs county vs
  // municipal vs aggregator and surface DoD / VA / GSA sub-tiers.
  agencyKind    AgencyKind  @default(FEDERAL)
  agencyTier    AgencyTier  @default(CIVILIAN)
  agencyName    String?
  geoScope      String
  geoCity       String?
  geoState      String?
  geoCountry    String      @default("US")
  authType      String      @default("NONE")
  signupUrl     String?
  description   String?
  naicsFocus    String?
  setAsideFocus String?
  // scraperKind names the integration backing this portal. MANUAL means
  // no auto-scraper — operators visit the portal's UI directly. The
  // sweep dispatcher refuses to run MANUAL/DEPRECATED portals so the
  // app never fabricates listings.
  scraperKind   ScraperKind @default(MANUAL)
  // scraperModule names the file under src/lib/scrapers/<name>.ts when
  // scraperKind is API/RSS/HTML. Empty for MANUAL/DEPRECATED.
  scraperModule String?
  // Verification telemetry — written by scripts/verify-html-scrapers.ts
  // and the periodic sweep cron. lastVerifiedAt is null until the
  // first probe; lastVerifiedOk records the binary outcome;
  // lastVerifiedNote captures the failure mode (e.g., "404", "no
  // tables", "captcha"). Surfaced on the /bids/portal-coverage admin
  // page so ops staff can prioritize portal-scraper backlog.
  lastVerifiedAt    DateTime?
  lastVerifiedOk    Boolean?
  lastVerifiedCount Int?
  lastVerifiedNote  String?
  active            Boolean   @default(true)
  createdAt         DateTime  @default(now())

  rfpSources RfpSource[]

  @@index([active])
  @@index([agencyKind, agencyTier])
  @@index([scraperKind])
  @@index([lastVerifiedOk, scraperKind])
}

model RfpListing {
  id                 String           @id @default(cuid())
  tenantId           String
  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sourceId           String?
  source             RfpSource?       @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  title              String
  agency             String
  agencyKind         AgencyKind?
  agencyTier         AgencyTier?
  solicitationNo     String?
  url                String?
  summary            String?
  estimatedValue     Float?
  dueAt              DateTime?
  postedAt           DateTime?
  setAside           String?
  naicsCode          String?
  placeOfPerformance String?
  matched            Boolean          @default(false)
  status             RfpListingStatus @default(NEW)
  // Match score 0-100 against the tenant's bid profile. NULL means
  // "not yet scored." scoreExplanation is a JSON string with the
  // signal breakdown so the UI can render "matched on NAICS, missed
  // on geo" tooltips and the operator can audit the ranking.
  score              Int?
  scoreExplanation   String?
  // Auto-draft attempt status (added 2026-05-01). When the sweep
  // auto-fires autopilotListing on a hot listing, we record the
  // outcome here so the UI can show "auto-drafted on date X" without
  // walking AuditEvent rows.
  autoDrafted        Boolean          @default(false)
  autoDraftedAt      DateTime?
  autoDraftError     String?
  opportunityId      String?
  opportunity        Opportunity?     @relation(fields: [opportunityId], references: [id], onDelete: SetNull)
  ownerName          String?
  discoveredAt       DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  bidDrafts BidDraft[]

  @@index([tenantId])
  @@index([sourceId])
  @@index([tenantId, score])
  @@index([tenantId, dueAt])
  // Prevent double-ingest from concurrent sweeps. SQLite treats NULL
  // values as distinct in unique indexes (per SQL standard), so
  // listings without a solicitationNo can still co-exist — but
  // real-numbered listings can't be duplicated for the same tenant +
  // agency. Pairs with the upsert in src/lib/rfp-crawl.ts.
  @@unique([tenantId, agency, solicitationNo], name: "tenant_agency_sol_unique")
}

/// Per-tenant matching profile — what makes a listing a "good fit" for
/// THIS tenant. Used by the scoring engine to assign 0-100 scores at
/// sweep time. Each field is JSON-encoded to keep the schema stable as
/// the matching logic evolves.
///
/// Pass-11 (2026-05-01): added to support auto-tracking and auto-draft
/// across federal / state / county / municipal pipelines.
model TenantBidProfile {
  id                     String   @id @default(cuid())
  tenantId               String   @unique
  tenant                 Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  // Comma-separated NAICS codes the tenant pursues. Listings whose
  // naicsCode matches any of these score full points on NAICS.
  targetNaicsJson        String   @default("[]")
  // Set-aside codes the tenant qualifies for (SDVOSB, EIGHT_A, WOSB,
  // HUBZONE, SMALL_BUSINESS, NONE). Listings whose setAside is in this
  // list score full points; UNKNOWN listings (no setAside) score
  // partial.
  qualifiedSetAsidesJson String   @default("[]")
  // Geographic preference. Listings within targetStates or
  // targetCities score full geo points; further away gets partial.
  targetStatesJson       String   @default("[]")
  targetCitiesJson       String   @default("[]")
  // Dollar value range — listings outside the range take a hit.
  minValue               Float?
  maxValue               Float?
  // Keywords / phrases boosting score when found in title/summary.
  boostKeywordsJson      String   @default("[]")
  // Keywords that should subtract from score (e.g. "demolition only"
  // for a tenant that doesn't do demo work).
  blockKeywordsJson      String   @default("[]")
  // Per-agency-tier preference — array of AgencyTier values. Empty
  // array means no preference.
  preferredTiersJson     String   @default("[]")
  // The score floor at which a listing becomes "hot" — surfaced in
  // dashboards, gets a notification, and (if the source allows)
  // qualifies for auto-draft.
  hotThreshold           Int      @default(70)
  notes                  String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([tenantId])
}

